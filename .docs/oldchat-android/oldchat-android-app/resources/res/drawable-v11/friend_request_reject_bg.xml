<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/color_surface_pressed"/>
            <stroke
                android:width="1dp"
                android:color="@color/color_primary"/>
            <size
                android:height="36dp"
                android:width="36dp"/>
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/color_surface"/>
            <stroke
                android:width="1dp"
                android:color="@color/color_surface_stroke"/>
            <size
                android:height="36dp"
                android:width="36dp"/>
        </shape>
    </item>
</selector>
