<?xml version="1.0" encoding="utf-8"?>
<com.im.oldchat.ui.widget.TiltFrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="6dp">
    <RelativeLayout
        android:background="@drawable/bg_flat_row_selector"
        android:paddingLeft="12dp"
        android:paddingTop="10dp"
        android:paddingRight="12dp"
        android:paddingBottom="10dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="60dp">
        <ImageView
            android:id="@+id/ivAvatar"
            android:background="@drawable/bg_avatar_round"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:scaleType="centerCrop"
            android:layout_alignParentLeft="true"
            android:layout_centerVertical="true"
            app:srcCompat="@drawable/ic_avatar_placeholder"/>
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="10dp"
            android:layout_marginRight="8dp"
            android:layout_toLeftOf="@+id/ivChevron"
            android:layout_toRightOf="@+id/ivAvatar"
            android:layout_centerVertical="true">
            <LinearLayout
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/color_text_primary"
                    android:ellipsize="end"
                    android:id="@+id/tvName"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:maxLines="1"
                    android:layout_weight="1"/>
                <TextView
                    android:textSize="9sp"
                    android:textColor="@android:color/white"
                    android:ellipsize="end"
                    android:gravity="center"
                    android:id="@+id/tvTitleBadge"
                    android:background="@drawable/bg_pastel_pill_red"
                    android:paddingLeft="8dp"
                    android:paddingTop="1dp"
                    android:paddingRight="8dp"
                    android:paddingBottom="1dp"
                    android:visibility="gone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="6dp"
                    android:maxWidth="92dp"
                    android:maxLines="1"
                    android:singleLine="true"
                    android:includeFontPadding="false"/>
            </LinearLayout>
            <TextView
                android:textSize="12sp"
                android:textColor="@color/color_text_secondary"
                android:ellipsize="end"
                android:id="@+id/tvSignature"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:maxLines="1"/>
        </LinearLayout>
        <ImageView
            android:id="@+id/ivChevron"
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:tint="@color/color_text_secondary"
            android:layout_alignParentRight="true"
            android:layout_centerVertical="true"
            android:contentDescription="@null"
            app:srcCompat="@android:drawable/ic_media_next"/>
    </RelativeLayout>
</com.im.oldchat.ui.widget.TiltFrameLayout>
