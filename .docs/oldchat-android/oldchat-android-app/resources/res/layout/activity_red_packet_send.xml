<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="@color/color_background"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:background="@color/color_surface"
        android:padding="12dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <ImageView
            android:id="@+id/btnRedPacketSendBack"
            android:padding="6dp"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_nav_back"
            android:tint="@color/color_text_primary"
            android:contentDescription="@null"/>
        <TextView
            android:textSize="18sp"
            android:textColor="@color/color_text_primary"
            android:id="@+id/tvRedPacketSendTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="8dp"
            android:text="@string/red_packet_title"/>
    </LinearLayout>
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">
        <LinearLayout
            android:orientation="vertical"
            android:padding="14dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:textSize="13sp"
                android:textColor="@color/color_text_secondary"
                android:id="@+id/tvRedPacketTarget"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
            <LinearLayout
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:background="@drawable/bg_profile_item"
                android:padding="10dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp">
                <ImageView
                    android:id="@+id/ivRedPacketCoverPreview"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:src="@drawable/ic_red_packet"
                    android:scaleType="centerCrop"
                    android:contentDescription="@null"/>
                <LinearLayout
                    android:orientation="vertical"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="10dp"
                    android:layout_weight="1">
                    <TextView
                        android:textSize="12sp"
                        android:textColor="@color/color_text_secondary"
                        android:id="@+id/tvRedPacketCoverHint"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/red_packet_image_hint"/>
                    <TextView
                        android:textSize="13sp"
                        android:textColor="@color/color_button_text"
                        android:gravity="center"
                        android:id="@+id/btnRedPacketPickCover"
                        android:background="@drawable/flat_button_bg"
                        android:layout_width="match_parent"
                        android:layout_height="36dp"
                        android:layout_marginTop="8dp"
                        android:text="@string/red_packet_image_pick"/>
                    <TextView
                        android:textSize="12sp"
                        android:textColor="@color/color_text_secondary"
                        android:gravity="center"
                        android:id="@+id/btnRedPacketClearCover"
                        android:background="@drawable/bg_profile_item"
                        android:visibility="gone"
                        android:layout_width="match_parent"
                        android:layout_height="34dp"
                        android:layout_marginTop="6dp"
                        android:text="@string/red_packet_image_clear"/>
                </LinearLayout>
            </LinearLayout>
            <EditText
                android:textColor="@color/color_text_primary"
                android:textColorHint="@color/color_text_secondary"
                android:id="@+id/etRedPacketTitle"
                android:background="@drawable/bg_profile_item"
                android:padding="12dp"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="12dp"
                android:hint="@string/red_packet_name_hint"
                android:maxLength="20"/>
            <EditText
                android:textColor="@color/color_text_primary"
                android:textColorHint="@color/color_text_secondary"
                android:id="@+id/etRedPacketAmount"
                android:background="@drawable/bg_profile_item"
                android:padding="12dp"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="12dp"
                android:hint="@string/red_packet_amount_hint"
                android:inputType="number"/>
            <EditText
                android:textColor="@color/color_text_primary"
                android:textColorHint="@color/color_text_secondary"
                android:id="@+id/etRedPacketCount"
                android:background="@drawable/bg_profile_item"
                android:padding="12dp"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="12dp"
                android:hint="@string/red_packet_count_hint"
                android:inputType="number"/>
            <TextView
                android:textColor="@color/color_button_text"
                android:gravity="center"
                android:id="@+id/btnSendRedPacket"
                android:background="@drawable/flat_button_bg"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="20dp"
                android:text="@string/red_packet_send"/>
            <ProgressBar
                android:layout_gravity="center_horizontal"
                android:id="@+id/pbRedPacketSend"
                android:visibility="gone"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginTop="12dp"
                android:indeterminate="true"/>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
