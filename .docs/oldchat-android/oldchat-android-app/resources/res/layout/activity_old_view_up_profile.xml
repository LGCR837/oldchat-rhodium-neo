<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="@drawable/bg_old_view_detail_page"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:background="@drawable/bg_old_view_detail_topbar"
        android:paddingLeft="8dp"
        android:paddingRight="12dp"
        android:layout_width="match_parent"
        android:layout_height="56dp">
        <ImageView
            android:id="@+id/btnOldViewUpProfileBack"
            android:padding="8dp"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_nav_back"
            android:contentDescription="@null"/>
        <TextView
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/color_text_primary"
            android:ellipsize="end"
            android:id="@+id/tvOldViewUpProfileTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginLeft="8dp"
            android:text="@string/old_view_up_profile_title"
            android:maxLines="1"
            android:layout_weight="1"/>
    </LinearLayout>
    <ProgressBar
        android:id="@+id/pbOldViewUpProfileLoading"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:indeterminate="true"
        style="?android:attr/progressBarStyleHorizontal"/>
    <LinearLayout
        android:orientation="vertical"
        android:background="@drawable/bg_old_view_detail_card"
        android:paddingLeft="12dp"
        android:paddingTop="12dp"
        android:paddingRight="12dp"
        android:paddingBottom="12dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="12dp"
        android:layout_marginTop="10dp"
        android:layout_marginRight="12dp">
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <ImageView
                android:id="@+id/ivOldViewUpProfileAvatar"
                android:background="@drawable/bg_avatar_round"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:src="@drawable/ic_avatar_placeholder"
                android:scaleType="centerCrop"
                android:contentDescription="@null"/>
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginLeft="10dp"
                android:layout_weight="1">
                <TextView
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/color_text_primary"
                    android:ellipsize="end"
                    android:id="@+id/tvOldViewUpProfileName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/old_view_up_profile_title"
                    android:maxLines="1"/>
                <TextView
                    android:textSize="12sp"
                    android:textColor="@color/color_text_secondary"
                    android:ellipsize="end"
                    android:id="@+id/tvOldViewUpProfileUid"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:maxLines="1"/>
            </LinearLayout>
            <TextView
                android:textSize="12sp"
                android:textColor="@color/color_on_primary"
                android:gravity="center"
                android:id="@+id/btnOldViewUpProfileFollow"
                android:background="@drawable/bg_old_view_action_active"
                android:layout_width="78dp"
                android:layout_height="32dp"
                android:layout_marginLeft="8dp"
                android:text="@string/old_view_up_follow"/>
        </LinearLayout>
        <TextView
            android:textSize="12sp"
            android:textColor="@color/color_text_secondary"
            android:ellipsize="end"
            android:id="@+id/tvOldViewUpProfileSign"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="这个 UP 很神秘，暂时没有简介"
            android:maxLines="2"/>
        <LinearLayout
            android:orientation="horizontal"
            android:background="@drawable/bg_old_view_detail_topbar"
            android:paddingLeft="8dp"
            android:paddingTop="6dp"
            android:paddingRight="8dp"
            android:paddingBottom="6dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp">
            <TextView
                android:textSize="12sp"
                android:textColor="@color/color_text_primary"
                android:gravity="center"
                android:id="@+id/tvOldViewUpProfileFollower"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="粉丝 0"
                android:layout_weight="1"/>
            <TextView
                android:textSize="12sp"
                android:textColor="@color/color_text_primary"
                android:gravity="center"
                android:id="@+id/tvOldViewUpProfileFollowing"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="关注 0"
                android:layout_weight="1"/>
            <TextView
                android:textSize="12sp"
                android:textColor="@color/color_text_primary"
                android:gravity="center"
                android:id="@+id/tvOldViewUpProfileArchive"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="投稿 0"
                android:layout_weight="1"/>
        </LinearLayout>
    </LinearLayout>
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="12dp"
        android:layout_marginTop="8dp"
        android:layout_marginRight="12dp">
        <TextView
            android:textSize="12sp"
            android:textColor="@color/color_on_primary"
            android:gravity="center"
            android:id="@+id/tabOldViewUpProfileVideos"
            android:background="@drawable/bg_old_view_tab_active"
            android:layout_width="0dp"
            android:layout_height="30dp"
            android:text="投稿"
            android:layout_weight="1"/>
        <TextView
            android:textSize="12sp"
            android:textColor="@color/color_text_secondary"
            android:gravity="center"
            android:id="@+id/tabOldViewUpProfileSpace"
            android:background="@drawable/bg_old_view_tab_inactive"
            android:layout_width="0dp"
            android:layout_height="30dp"
            android:layout_marginLeft="8dp"
            android:text="主页"
            android:layout_weight="1"/>
    </LinearLayout>
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_weight="1">
        <ListView
            android:id="@+id/lvOldViewUpProfileVideos"
            android:background="@drawable/bg_old_view_detail_page"
            android:paddingLeft="12dp"
            android:paddingRight="12dp"
            android:paddingBottom="10dp"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:listSelector="@android:color/transparent"
            android:cacheColorHint="@android:color/transparent"
            android:divider="@android:color/transparent"
            android:dividerHeight="8dp"/>
        <WebView
            android:id="@+id/wvOldViewUpProfile"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>
        <TextView
            android:textSize="13sp"
            android:textColor="@color/color_text_secondary"
            android:gravity="center"
            android:id="@+id/tvOldViewUpProfileEmpty"
            android:padding="18dp"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="@string/old_view_up_profile_load_failed"/>
    </FrameLayout>
</LinearLayout>
