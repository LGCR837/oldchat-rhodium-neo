<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:id="@+id/sectionChatsRoot"
    android:padding="0dp"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="10dp">
    <com.im.oldchat.ui.widget.TiltFrameLayout
        android:layout_width="match_parent"
        android:layout_height="44dp">
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:id="@+id/headerChats"
            android:background="@drawable/bg_pastel_section_header"
            android:paddingLeft="12dp"
            android:paddingRight="12dp"
            android:focusable="true"
            android:clickable="true"
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <View
                android:id="@+id/dotChats"
                android:background="@drawable/bg_pastel_dot_open"
                android:layout_width="10dp"
                android:layout_height="10dp"/>
            <TextView
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/home_section_title_text"
                android:id="@+id/tvChatsTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginLeft="10dp"
                android:text="会话"
                android:layout_weight="1"/>
            <TextView
                android:textSize="11sp"
                android:textColor="@android:color/white"
                android:id="@+id/tvChatsCount"
                android:background="@drawable/bg_pastel_pill_red"
                android:paddingLeft="8dp"
                android:paddingTop="2dp"
                android:paddingRight="8dp"
                android:paddingBottom="2dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>
    </com.im.oldchat.ui.widget.TiltFrameLayout>
    <FrameLayout
        android:id="@+id/panelChats"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp">
        <LinearLayout
            android:orientation="vertical"
            android:id="@+id/contentChats"
            android:paddingTop="2dp"
            android:paddingBottom="2dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>
    </FrameLayout>
</LinearLayout>
