<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="@drawable/bg_profile_item"
    android:padding="12dp"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp">
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="@color/color_text_primary"
            android:id="@+id/tvTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"/>
        <TextView
            android:textSize="12sp"
            android:textColor="@color/color_text_primary"
            android:id="@+id/tvStatus"
            android:background="@drawable/flat_button_bg"
            android:paddingLeft="10dp"
            android:paddingTop="4dp"
            android:paddingRight="10dp"
            android:paddingBottom="4dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </LinearLayout>
    <TextView
        android:textSize="12sp"
        android:textColor="@color/color_text_secondary"
        android:id="@+id/tvProgress"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"/>
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp">
        <ImageView
            android:id="@+id/ivReporterAvatar"
            android:layout_width="22dp"
            android:layout_height="22dp"
            app:srcCompat="@drawable/ic_avatar_placeholder"/>
        <TextView
            android:textSize="12sp"
            android:textColor="@color/color_text_secondary"
            android:ellipsize="end"
            android:id="@+id/tvReporterName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginLeft="6dp"
            android:maxLines="1"
            android:layout_weight="1"/>
        <TextView
            android:textSize="11sp"
            android:textColor="@color/color_text_secondary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="6dp"
            android:layout_marginRight="6dp"
            android:text="对质"/>
        <ImageView
            android:id="@+id/ivDefendantAvatar"
            android:layout_width="22dp"
            android:layout_height="22dp"
            app:srcCompat="@drawable/ic_avatar_placeholder"/>
        <TextView
            android:textSize="12sp"
            android:textColor="@color/color_text_secondary"
            android:ellipsize="end"
            android:gravity="end"
            android:id="@+id/tvDefendantName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginLeft="6dp"
            android:maxLines="1"
            android:layout_weight="1"/>
    </LinearLayout>
    <TextView
        android:textSize="13sp"
        android:textColor="@color/color_text_primary"
        android:id="@+id/tvBody"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"/>
    <TextView
        android:textSize="12sp"
        android:textColor="@color/color_text_secondary"
        android:id="@+id/tvMeta"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"/>
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp">
        <TextView
            android:textSize="13sp"
            android:textColor="@color/color_text_primary"
            android:gravity="center"
            android:id="@+id/btnDetail"
            android:background="@drawable/flat_button_bg"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:text="查看详情"
            android:layout_weight="1"/>
        <TextView
            android:textSize="13sp"
            android:textColor="@color/color_text_primary"
            android:gravity="center"
            android:id="@+id/btnStatement"
            android:background="@drawable/flat_button_bg"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_marginLeft="8dp"
            android:text="补充观点"
            android:layout_weight="1"/>
    </LinearLayout>
</LinearLayout>
