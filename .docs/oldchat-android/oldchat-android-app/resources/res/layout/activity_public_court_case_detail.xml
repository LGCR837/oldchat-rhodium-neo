<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="@color/color_background"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:background="@color/color_surface"
        android:paddingLeft="12dp"
        android:paddingRight="16dp"
        android:layout_width="match_parent"
        android:layout_height="56dp">
        <ImageView
            android:id="@+id/btnBack"
            android:padding="6dp"
            android:layout_width="32dp"
            android:layout_height="32dp"
            app:srcCompat="@drawable/ic_nav_back"/>
        <TextView
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/color_text_primary"
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="8dp"
            android:text="案件详情"/>
    </LinearLayout>
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">
        <LinearLayout
            android:orientation="vertical"
            android:padding="12dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <LinearLayout
                android:orientation="vertical"
                android:background="@drawable/bg_profile_item"
                android:padding="12dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp">
                <TextView
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/color_text_primary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="案件概览"/>
                <TextView
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/color_text_primary"
                    android:id="@+id/tvCaseId"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"/>
                <LinearLayout
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp">
                    <TextView
                        android:textSize="12sp"
                        android:textColor="@color/color_text_primary"
                        android:id="@+id/tvStatus"
                        android:background="@drawable/flat_button_bg"
                        android:paddingLeft="10dp"
                        android:paddingTop="4dp"
                        android:paddingRight="10dp"
                        android:paddingBottom="4dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                    <TextView
                        android:textSize="12sp"
                        android:textColor="@color/color_text_secondary"
                        android:gravity="end"
                        android:id="@+id/tvOpenTime"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="8dp"
                        android:layout_weight="1"/>
                </LinearLayout>
                <TextView
                    android:textSize="13sp"
                    android:textColor="@color/color_text_secondary"
                    android:id="@+id/tvParticipants"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"/>
                <TextView
                    android:textSize="13sp"
                    android:textColor="@color/color_text_secondary"
                    android:id="@+id/tvVoteSummary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"/>
                <TextView
                    android:textSize="12sp"
                    android:textColor="@color/color_text_secondary"
                    android:id="@+id/tvStageHint"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"/>
                <LinearLayout
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp">
                    <ImageView
                        android:id="@+id/ivReporterAvatar"
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        app:srcCompat="@drawable/ic_avatar_placeholder"/>
                    <TextView
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@color/color_text_primary"
                        android:ellipsize="end"
                        android:id="@+id/tvReporterName"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="8dp"
                        android:maxLines="1"
                        android:layout_weight="1"/>
                    <TextView
                        android:textSize="12sp"
                        android:textColor="@color/color_text_secondary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="8dp"
                        android:layout_marginRight="8dp"
                        android:text="对质"/>
                    <TextView
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@color/color_text_primary"
                        android:ellipsize="end"
                        android:gravity="end"
                        android:id="@+id/tvDefendantName"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:maxLines="1"
                        android:layout_weight="1"/>
                    <ImageView
                        android:id="@+id/ivDefendantAvatar"
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:layout_marginLeft="8dp"
                        app:srcCompat="@drawable/ic_avatar_placeholder"/>
                </LinearLayout>
            </LinearLayout>
            <LinearLayout
                android:orientation="vertical"
                android:background="@drawable/bg_profile_item"
                android:padding="12dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp">
                <TextView
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/color_text_primary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="我的操作"/>
                <TextView
                    android:textSize="12sp"
                    android:textColor="@color/color_text_secondary"
                    android:id="@+id/tvActionHint"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"/>
                <LinearLayout
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp">
                    <TextView
                        android:textSize="13sp"
                        android:textColor="@android:color/white"
                        android:gravity="center"
                        android:id="@+id/btnVoteBan"
                        android:background="@drawable/flat_button_danger_bg"
                        android:layout_width="0dp"
                        android:layout_height="38dp"
                        android:text="投封禁"
                        android:layout_weight="1"/>
                    <TextView
                        android:textSize="13sp"
                        android:textColor="@android:color/white"
                        android:gravity="center"
                        android:id="@+id/btnVoteKeep"
                        android:background="@drawable/flat_button_accent_bg"
                        android:layout_width="0dp"
                        android:layout_height="38dp"
                        android:layout_marginLeft="8dp"
                        android:text="投不封"
                        android:layout_weight="1"/>
                </LinearLayout>
                <LinearLayout
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp">
                    <TextView
                        android:textSize="13sp"
                        android:textColor="@color/color_text_primary"
                        android:gravity="center"
                        android:id="@+id/btnStatement"
                        android:background="@drawable/flat_button_bg"
                        android:layout_width="0dp"
                        android:layout_height="38dp"
                        android:text="补充观点"
                        android:layout_weight="1"/>
                    <TextView
                        android:textSize="13sp"
                        android:textColor="@color/color_text_primary"
                        android:gravity="center"
                        android:id="@+id/btnRefresh"
                        android:background="@drawable/flat_button_bg"
                        android:paddingLeft="12dp"
                        android:paddingRight="12dp"
                        android:layout_width="wrap_content"
                        android:layout_height="38dp"
                        android:layout_marginLeft="8dp"
                        android:text="刷新"/>
                </LinearLayout>
                <TextView
                    android:textSize="13sp"
                    android:textColor="@android:color/white"
                    android:gravity="center"
                    android:id="@+id/btnWithdraw"
                    android:background="@drawable/flat_button_danger_bg"
                    android:layout_width="match_parent"
                    android:layout_height="38dp"
                    android:layout_marginTop="8dp"
                    android:text="撤销举报（仅发起者）"/>
            </LinearLayout>
            <LinearLayout
                android:orientation="vertical"
                android:background="@drawable/bg_profile_item"
                android:padding="12dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp">
                <TextView
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/color_text_primary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="当事双方观点"/>
                <TextView
                    android:textSize="12sp"
                    android:textColor="@color/color_text_secondary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="举报方理由"/>
                <TextView
                    android:textSize="13sp"
                    android:textColor="@color/color_text_primary"
                    android:id="@+id/tvReportReason"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"/>
                <TextView
                    android:textSize="12sp"
                    android:textColor="@color/color_text_secondary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="举报方证据说明"/>
                <TextView
                    android:textSize="13sp"
                    android:textColor="@color/color_text_primary"
                    android:id="@+id/tvReportEvidence"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"/>
                <TextView
                    android:textSize="12sp"
                    android:textColor="@color/color_text_secondary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="被举报方理由"/>
                <TextView
                    android:textSize="13sp"
                    android:textColor="@color/color_text_primary"
                    android:id="@+id/tvDefenseReason"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"/>
                <TextView
                    android:textSize="12sp"
                    android:textColor="@color/color_text_secondary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="被举报方证据说明"/>
                <TextView
                    android:textSize="13sp"
                    android:textColor="@color/color_text_primary"
                    android:id="@+id/tvDefenseEvidence"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>
            <LinearLayout
                android:orientation="vertical"
                android:background="@drawable/bg_profile_item"
                android:padding="12dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp">
                <TextView
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/color_text_primary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="全部观点与证据"/>
                <LinearLayout
                    android:orientation="vertical"
                    android:id="@+id/layoutStatements"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"/>
            </LinearLayout>
            <LinearLayout
                android:orientation="vertical"
                android:background="@drawable/bg_profile_item"
                android:padding="12dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp">
                <TextView
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/color_text_primary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="案件讨论"/>
                <LinearLayout
                    android:orientation="vertical"
                    android:id="@+id/layoutDiscussions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"/>
                <LinearLayout
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp">
                    <EditText
                        android:textSize="13sp"
                        android:textColor="@color/color_text_primary"
                        android:textColorHint="@color/color_text_secondary"
                        android:id="@+id/etDiscussionInput"
                        android:background="@drawable/bg_profile_item"
                        android:paddingLeft="10dp"
                        android:paddingRight="10dp"
                        android:layout_width="0dp"
                        android:layout_height="38dp"
                        android:hint="补充案件讨论（最多800字）"
                        android:maxLines="3"
                        android:layout_weight="1"/>
                    <TextView
                        android:textSize="13sp"
                        android:textColor="@color/color_text_primary"
                        android:gravity="center"
                        android:id="@+id/btnDiscussionSend"
                        android:background="@drawable/flat_button_bg"
                        android:paddingLeft="12dp"
                        android:paddingRight="12dp"
                        android:layout_width="wrap_content"
                        android:layout_height="38dp"
                        android:layout_marginLeft="8dp"
                        android:text="发送"/>
                </LinearLayout>
            </LinearLayout>
            <LinearLayout
                android:orientation="vertical"
                android:background="@drawable/bg_profile_item"
                android:padding="12dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="18dp">
                <TextView
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/color_text_primary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="管理员裁决"/>
                <TextView
                    android:textSize="13sp"
                    android:textColor="@color/color_text_primary"
                    android:id="@+id/tvAdminResult"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"/>
                <TextView
                    android:textSize="13sp"
                    android:textColor="@color/color_text_secondary"
                    android:id="@+id/tvAdminNote"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"/>
            </LinearLayout>
            <LinearLayout
                android:orientation="vertical"
                android:background="@drawable/bg_profile_item"
                android:padding="12dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp">
                <TextView
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/color_text_primary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="叠加举报记录"/>
                <LinearLayout
                    android:orientation="vertical"
                    android:id="@+id/layoutMergedReports"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"/>
                <LinearLayout
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp">
                    <TextView
                        android:textSize="12sp"
                        android:textColor="@color/color_text_primary"
                        android:gravity="center"
                        android:id="@+id/btnMergedReportPrev"
                        android:background="@drawable/flat_button_bg"
                        android:paddingLeft="10dp"
                        android:paddingRight="10dp"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:text="上一页"/>
                    <TextView
                        android:textSize="12sp"
                        android:textColor="@color/color_text_secondary"
                        android:gravity="center"
                        android:id="@+id/tvMergedReportPage"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="8dp"
                        android:layout_marginRight="8dp"
                        android:layout_weight="1"/>
                    <TextView
                        android:textSize="12sp"
                        android:textColor="@color/color_text_primary"
                        android:gravity="center"
                        android:id="@+id/btnMergedReportNext"
                        android:background="@drawable/flat_button_bg"
                        android:paddingLeft="10dp"
                        android:paddingRight="10dp"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:text="下一页"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
