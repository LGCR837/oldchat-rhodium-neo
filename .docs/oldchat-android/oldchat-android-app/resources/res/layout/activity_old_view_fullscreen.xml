<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="#000000"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <VideoView
        android:id="@+id/vvOldViewFullPlayer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>
    <LinearLayout
        android:gravity="center_horizontal"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:id="@+id/layoutOldViewFullLoading"
        android:background="#66000000"
        android:paddingLeft="14dp"
        android:paddingTop="10dp"
        android:paddingRight="14dp"
        android:paddingBottom="10dp"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content">
        <ProgressBar
            android:id="@+id/pbOldViewFullLoading"
            android:layout_width="30dp"
            android:layout_height="30dp"
            style="?android:attr/progressBarStyle"/>
        <TextView
            android:textSize="12sp"
            android:textColor="@android:color/white"
            android:id="@+id/tvOldViewFullHint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="视频加载中..."/>
    </LinearLayout>
    <LinearLayout
        android:gravity="center_vertical"
        android:layout_gravity="top"
        android:orientation="horizontal"
        android:id="@+id/layoutOldViewFullTop"
        android:background="#66000000"
        android:paddingLeft="10dp"
        android:paddingTop="8dp"
        android:paddingRight="10dp"
        android:paddingBottom="8dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:textSize="12sp"
            android:textColor="@android:color/white"
            android:gravity="center"
            android:id="@+id/btnOldViewFullBack"
            android:background="#55000000"
            android:paddingLeft="12dp"
            android:paddingRight="12dp"
            android:layout_width="wrap_content"
            android:layout_height="30dp"
            android:minWidth="56dp"
            android:text="返回"/>
        <TextView
            android:textSize="13sp"
            android:textColor="@android:color/white"
            android:ellipsize="end"
            android:id="@+id/tvOldViewFullTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginLeft="10dp"
            android:maxLines="1"
            android:layout_weight="1"/>
    </LinearLayout>
    <TextView
        android:textSize="11sp"
        android:textColor="#ccffffff"
        android:gravity="center"
        android:layout_gravity="bottom"
        android:id="@+id/tvOldViewFullBottomHint"
        android:background="#44000000"
        android:paddingLeft="10dp"
        android:paddingTop="6dp"
        android:paddingRight="10dp"
        android:paddingBottom="6dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="双击可使用系统控制器，返回可继续播放"/>
</FrameLayout>
