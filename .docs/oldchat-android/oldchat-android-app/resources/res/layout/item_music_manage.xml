<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:background="@drawable/bg_music_plaza_card_selector"
    android:padding="10dp"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginLeft="8dp"
    android:layout_marginTop="5dp"
    android:layout_marginRight="8dp"
    android:layout_marginBottom="5dp">
    <ImageView
        android:id="@+id/ivMusicManageCover"
        android:background="@drawable/bg_music_plaza_cover_frame"
        android:padding="1dp"
        android:layout_width="62dp"
        android:layout_height="62dp"
        android:src="@drawable/ic_avatar_placeholder"
        android:scaleType="centerCrop"
        android:contentDescription="@null"/>
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginLeft="10dp"
        android:layout_weight="1">
        <TextView
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="@color/color_text_primary"
            android:ellipsize="end"
            android:id="@+id/tvMusicManageName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="歌曲名称"
            android:maxLines="1"/>
        <TextView
            android:textSize="12sp"
            android:textColor="@color/color_text_secondary"
            android:ellipsize="end"
            android:id="@+id/tvMusicManageOwner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="上传信息"
            android:maxLines="1"/>
        <TextView
            android:textSize="11sp"
            android:textColor="@color/color_text_secondary"
            android:ellipsize="end"
            android:id="@+id/tvMusicManageMeta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="时长 --:-- · 大小 0KB"
            android:maxLines="1"/>
        <TextView
            android:textSize="11sp"
            android:textColor="@color/color_text_secondary"
            android:ellipsize="end"
            android:id="@+id/tvMusicManageStats"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="赞 0 · 评论 0"
            android:maxLines="1"/>
    </LinearLayout>
    <LinearLayout
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content">
        <TextView
            android:textSize="12sp"
            android:textColor="@color/color_on_primary"
            android:gravity="center"
            android:id="@+id/btnMusicManagePlay"
            android:background="@drawable/bg_music_top_chip_primary"
            android:paddingLeft="10dp"
            android:paddingRight="10dp"
            android:layout_width="wrap_content"
            android:layout_height="30dp"
            android:minWidth="56dp"
            android:text="播放"/>
        <TextView
            android:textSize="12sp"
            android:textColor="@color/colorDanger"
            android:gravity="center"
            android:id="@+id/btnMusicManageDelete"
            android:background="@drawable/bg_music_action_delete"
            android:paddingLeft="10dp"
            android:paddingRight="10dp"
            android:layout_width="wrap_content"
            android:layout_height="30dp"
            android:layout_marginTop="6dp"
            android:minWidth="56dp"
            android:text="删除"/>
        <TextView
            android:textSize="12sp"
            android:textColor="@color/color_text_primary"
            android:gravity="center"
            android:id="@+id/btnMusicManageMore"
            android:background="@drawable/bg_music_top_chip"
            android:paddingLeft="10dp"
            android:paddingRight="10dp"
            android:layout_width="wrap_content"
            android:layout_height="30dp"
            android:layout_marginTop="6dp"
            android:minWidth="56dp"
            android:text="更多"/>
    </LinearLayout>
</LinearLayout>
