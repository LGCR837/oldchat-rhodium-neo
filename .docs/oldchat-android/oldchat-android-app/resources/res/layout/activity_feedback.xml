<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="@color/color_background"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:background="@color/color_surface"
        android:padding="12dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <ImageView
            android:id="@+id/btnBack"
            android:padding="6dp"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:tint="@color/color_text_primary"
            app:srcCompat="@drawable/ic_nav_back"/>
        <TextView
            android:textSize="18sp"
            android:textColor="@color/color_text_primary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="8dp"
            android:text="反馈问题"/>
    </LinearLayout>
    <View
        android:background="@color/color_divider"
        android:layout_width="match_parent"
        android:layout_height="1dp"/>
    <LinearLayout
        android:orientation="vertical"
        android:padding="16dp"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">
        <TextView
            android:textSize="14sp"
            android:textColor="@color/color_text_primary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="请描述您遇到的问题"/>
        <EditText
            android:textSize="15sp"
            android:textColor="@color/color_text_primary"
            android:textColorHint="@color/color_text_secondary"
            android:gravity="top|left"
            android:id="@+id/etContent"
            android:background="@drawable/flat_input_bg"
            android:padding="12dp"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:hint="请详细描述问题，我们会尽快处理..."
            android:inputType="textMultiLine"/>
        <TextView
            android:textSize="12sp"
            android:textColor="@color/color_text_secondary"
            android:id="@+id/tvDeviceInfo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"/>
    </LinearLayout>
    <LinearLayout
        android:orientation="vertical"
        android:padding="16dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <Button
            android:textSize="16sp"
            android:textColor="@android:color/white"
            android:id="@+id/btnSubmit"
            android:background="@drawable/flat_button_accent_bg"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="提交反馈"/>
    </LinearLayout>
</LinearLayout>
