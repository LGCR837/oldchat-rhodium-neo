<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="@color/color_background"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:background="@color/color_surface"
        android:paddingLeft="12dp"
        android:paddingRight="12dp"
        android:layout_width="match_parent"
        android:layout_height="56dp">
        <ImageView
            android:id="@+id/btnEmojiPlazaBack"
            android:padding="6dp"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_nav_back"
            android:contentDescription="@null"/>
        <TextView
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/color_text_primary"
            android:id="@+id/tvEmojiPlazaTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginLeft="8dp"
            android:text="表情包广场"
            android:layout_weight="1"/>
        <TextView
            android:textSize="14sp"
            android:textColor="@color/color_on_primary"
            android:gravity="center"
            android:id="@+id/btnEmojiPlazaUpload"
            android:background="@drawable/bg_primary_button"
            android:paddingLeft="12dp"
            android:paddingRight="12dp"
            android:layout_width="wrap_content"
            android:layout_height="34dp"
            android:minWidth="64dp"
            android:text="上传"/>
    </LinearLayout>
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:background="@drawable/bg_list_item_surface"
        android:padding="8dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="12dp"
        android:layout_marginTop="10dp"
        android:layout_marginRight="12dp"
        android:layout_marginBottom="8dp">
        <EditText
            android:textColor="@color/color_text_primary"
            android:textColorHint="@color/color_text_secondary"
            android:id="@+id/etEmojiPlazaKeyword"
            android:background="@drawable/bg_search_field"
            android:paddingLeft="10dp"
            android:paddingRight="10dp"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:hint="搜索表情名称"
            android:singleLine="true"
            android:layout_weight="1"
            android:imeOptions="actionSearch"/>
        <TextView
            android:textSize="14sp"
            android:textColor="@color/color_text_primary"
            android:gravity="center"
            android:id="@+id/btnEmojiPlazaSearch"
            android:background="@drawable/flat_button_bg"
            android:paddingLeft="14dp"
            android:paddingRight="14dp"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:layout_marginLeft="8dp"
            android:minWidth="64dp"
            android:text="搜索"/>
    </LinearLayout>
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:id="@+id/layoutEmojiPlazaTabs"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="12dp"
        android:layout_marginRight="12dp"
        android:layout_marginBottom="6dp">
        <TextView
            android:textSize="13sp"
            android:textColor="@color/color_on_primary"
            android:gravity="center"
            android:id="@+id/btnEmojiPlazaTabAll"
            android:background="@drawable/bg_primary_button"
            android:layout_width="0dp"
            android:layout_height="34dp"
            android:text="广场"
            android:layout_weight="1"/>
        <TextView
            android:textSize="13sp"
            android:textColor="@color/color_text_primary"
            android:gravity="center"
            android:id="@+id/btnEmojiPlazaTabMine"
            android:background="@drawable/flat_button_bg"
            android:layout_width="0dp"
            android:layout_height="34dp"
            android:layout_marginLeft="8dp"
            android:text="我上传的"
            android:layout_weight="1"/>
    </LinearLayout>
    <TextView
        android:textSize="12sp"
        android:textColor="@color/color_text_secondary"
        android:id="@+id/tvEmojiPlazaHint"
        android:paddingLeft="14dp"
        android:paddingTop="2dp"
        android:paddingRight="14dp"
        android:paddingBottom="6dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="可上传自己的表情，也可保存别人上传的表情到本地"/>
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:id="@+id/layoutEmojiPlazaPager"
        android:paddingLeft="14dp"
        android:paddingTop="2dp"
        android:paddingRight="14dp"
        android:paddingBottom="6dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:textSize="12sp"
            android:textColor="@color/color_text_secondary"
            android:ellipsize="end"
            android:id="@+id/tvEmojiPlazaPageInfo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text=""
            android:singleLine="true"
            android:layout_weight="1"/>
        <TextView
            android:textSize="12sp"
            android:textColor="@color/color_text_primary"
            android:gravity="center"
            android:id="@+id/btnEmojiPlazaPrev"
            android:background="@drawable/flat_button_bg"
            android:paddingLeft="10dp"
            android:paddingRight="10dp"
            android:layout_width="wrap_content"
            android:layout_height="30dp"
            android:minWidth="52dp"
            android:text="上一页"/>
        <TextView
            android:textSize="12sp"
            android:textColor="@color/color_text_primary"
            android:gravity="center"
            android:id="@+id/btnEmojiPlazaNext"
            android:background="@drawable/flat_button_bg"
            android:paddingLeft="10dp"
            android:paddingRight="10dp"
            android:layout_width="wrap_content"
            android:layout_height="30dp"
            android:layout_marginLeft="8dp"
            android:minWidth="52dp"
            android:text="下一页"/>
    </LinearLayout>
    <FrameLayout
        android:background="@drawable/bg_list_item_surface"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginLeft="10dp"
        android:layout_marginRight="10dp"
        android:layout_marginBottom="10dp"
        android:layout_weight="1">
        <ListView
            android:id="@+id/lvEmojiPlaza"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:clipToPadding="false"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:listSelector="@android:color/transparent"
            android:divider="@android:color/transparent"
            android:dividerHeight="0dp"/>
        <TextView
            android:textSize="14sp"
            android:textColor="@color/color_text_secondary"
            android:gravity="center"
            android:layout_gravity="center"
            android:id="@+id/tvEmojiPlazaEmpty"
            android:padding="24dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="暂无表情，快来上传第一个吧"/>
    </FrameLayout>
</LinearLayout>
