<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="@color/color_surface"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <LinearLayout
        android:gravity="top"
        android:orientation="horizontal"
        android:paddingLeft="12dp"
        android:paddingTop="12dp"
        android:paddingRight="12dp"
        android:paddingBottom="10dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <com.im.oldchat.ui.widget.RoundedImageView
            android:id="@+id/ivMomentAvatar"
            android:background="@drawable/bg_avatar_round"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:scaleType="centerCrop"
            android:contentDescription="@null"
            app:cornerRadius="0dp"
            app:srcCompat="@drawable/ic_avatar_placeholder"/>
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginLeft="10dp"
            android:layout_weight="1">
            <LinearLayout
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">
                <TextView
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/colorOwnerTag"
                    android:ellipsize="end"
                    android:id="@+id/tvMomentName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:maxLines="1"/>
                <TextView
                    android:textSize="10sp"
                    android:textColor="@color/color_on_primary"
                    android:ellipsize="end"
                    android:gravity="center"
                    android:id="@+id/tvMomentTitleBadge"
                    android:background="@drawable/bg_badge_title"
                    android:paddingLeft="4dp"
                    android:paddingTop="1dp"
                    android:paddingRight="4dp"
                    android:paddingBottom="1dp"
                    android:visibility="gone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="6dp"
                    android:maxWidth="84dp"
                    android:text="头衔"
                    android:maxLines="1"
                    android:singleLine="true"
                    android:includeFontPadding="false"/>
            </LinearLayout>
            <TextView
                android:textSize="15sp"
                android:textColor="@color/color_text_primary"
                android:id="@+id/tvMomentBody"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:lineSpacingExtra="1dp"/>
            <FrameLayout
                android:id="@+id/flMomentImage"
                android:background="@color/color_divider"
                android:visibility="gone"
                android:layout_width="210dp"
                android:layout_height="210dp"
                android:layout_marginTop="8dp">
                <com.im.oldchat.ui.widget.RoundedImageView
                    android:id="@+id/ivMomentImage"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:contentDescription="@null"
                    app:cornerRadius="0dp"/>
                <TextView
                    android:textSize="11sp"
                    android:textColor="@color/color_on_primary"
                    android:layout_gravity="bottom|right"
                    android:id="@+id/tvMomentImageCount"
                    android:background="@drawable/bg_unread_badge"
                    android:paddingLeft="6dp"
                    android:paddingTop="2dp"
                    android:paddingRight="6dp"
                    android:paddingBottom="2dp"
                    android:visibility="gone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_margin="6dp"
                    android:contentDescription="@null"/>
            </FrameLayout>
            <LinearLayout
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp">
                <TextView
                    android:textSize="12sp"
                    android:textColor="@color/color_text_secondary"
                    android:id="@+id/tvMomentTime"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"/>
                <LinearLayout
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:background="@drawable/moment_action_bg"
                    android:layout_width="wrap_content"
                    android:layout_height="30dp">
                    <LinearLayout
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:id="@+id/btnMomentLike"
                        android:paddingLeft="10dp"
                        android:paddingRight="10dp"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent">
                        <ImageView
                            android:id="@+id/ivLikeIcon"
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:tint="@color/color_text_secondary"
                            android:contentDescription="@null"
                            app:srcCompat="@drawable/ic_like"/>
                        <TextView
                            android:textSize="12sp"
                            android:textColor="@color/color_text_secondary"
                            android:id="@+id/tvLikeCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="4dp"
                            android:text="赞"/>
                    </LinearLayout>
                    <View
                        android:background="@color/color_divider"
                        android:layout_width="1dp"
                        android:layout_height="14dp"/>
                    <LinearLayout
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:id="@+id/btnMomentComment"
                        android:paddingLeft="10dp"
                        android:paddingRight="10dp"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent">
                        <ImageView
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:tint="@color/color_text_secondary"
                            android:contentDescription="@null"
                            app:srcCompat="@drawable/ic_comment"/>
                        <TextView
                            android:textSize="12sp"
                            android:textColor="@color/color_text_secondary"
                            android:id="@+id/tvCommentCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="4dp"
                            android:text="评论"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
            <TextView
                android:textSize="12sp"
                android:textColor="@color/color_text_secondary"
                android:id="@+id/tvMomentCounts"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"/>
        </LinearLayout>
    </LinearLayout>
    <View
        android:background="@color/color_divider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginLeft="64dp"/>
</LinearLayout>
