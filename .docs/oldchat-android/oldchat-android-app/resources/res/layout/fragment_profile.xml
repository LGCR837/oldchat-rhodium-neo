<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/color_background"
    android:scrollbars="none"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">
    <LinearLayout
        android:orientation="vertical"
        android:paddingLeft="14dp"
        android:paddingTop="12dp"
        android:paddingRight="14dp"
        android:paddingBottom="14dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/color_text_primary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="个人"/>
        <TextView
            android:textSize="12sp"
            android:textColor="@color/color_text_secondary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="账号与常用入口"/>
        <com.im.oldchat.ui.widget.TiltFrameLayout
            android:id="@+id/profile_card"
            android:background="@drawable/bg_flat_row_selector"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp">
            <RelativeLayout
                android:paddingLeft="12dp"
                android:paddingTop="12dp"
                android:paddingRight="12dp"
                android:paddingBottom="12dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="104dp">
                <com.im.oldchat.ui.widget.RoundedImageView
                    android:id="@+id/ivAvatar"
                    android:background="@drawable/bg_avatar_round"
                    android:layout_width="68dp"
                    android:layout_height="68dp"
                    android:scaleType="centerCrop"
                    android:layout_alignParentLeft="true"
                    android:layout_centerVertical="true"
                    android:contentDescription="@null"
                    app:cornerRadius="0dp"
                    app:srcCompat="@drawable/ic_avatar_placeholder"/>
                <TextView
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/color_text_primary"
                    android:id="@+id/tvMyUsername"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="12dp"
                    android:layout_toRightOf="@+id/ivAvatar"/>
                <TextView
                    android:textSize="10sp"
                    android:textColor="@android:color/white"
                    android:ellipsize="end"
                    android:id="@+id/tvMyTitleBadge"
                    android:background="@drawable/bg_pastel_pill_red"
                    android:paddingLeft="8dp"
                    android:paddingTop="2dp"
                    android:paddingRight="8dp"
                    android:paddingBottom="2dp"
                    android:visibility="gone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="6dp"
                    android:maxLines="1"
                    android:includeFontPadding="false"
                    android:layout_toRightOf="@+id/tvMyUsername"
                    android:layout_alignBaseline="@+id/tvMyUsername"/>
                <TextView
                    android:textSize="13sp"
                    android:textColor="@color/color_text_secondary"
                    android:id="@+id/tvMyEmail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="12dp"
                    android:layout_marginTop="6dp"
                    android:layout_toRightOf="@+id/ivAvatar"
                    android:layout_below="@+id/tvMyUsername"/>
                <TextView
                    android:textSize="13sp"
                    android:textColor="@color/color_text_secondary"
                    android:id="@+id/tvWalletBalance"
                    android:tag="square_mono"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="12dp"
                    android:layout_marginTop="4dp"
                    android:text="@string/profile_wallet_amount_default"
                    android:layout_toRightOf="@+id/ivAvatar"
                    android:layout_below="@+id/tvMyEmail"/>
                <TextView
                    android:textSize="13sp"
                    android:textColor="@color/color_text_secondary"
                    android:id="@+id/tvReputationScore"
                    android:tag="square_mono"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="12dp"
                    android:layout_marginTop="2dp"
                    android:text="@string/profile_reputation_default"
                    android:layout_toRightOf="@+id/ivAvatar"
                    android:layout_below="@+id/tvWalletBalance"/>
                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:tint="@color/color_text_secondary"
                    android:layout_alignParentRight="true"
                    android:layout_centerVertical="true"
                    android:contentDescription="@null"
                    app:srcCompat="@android:drawable/ic_media_next"/>
            </RelativeLayout>
        </com.im.oldchat.ui.widget.TiltFrameLayout>
        <TextView
            android:textSize="11sp"
            android:textColor="@color/color_text_secondary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="快捷入口"/>
        <com.im.oldchat.ui.widget.TiltFrameLayout
            android:id="@+id/btnMySpace"
            android:background="@drawable/bg_flat_row_selector"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="6dp">
            <LinearLayout
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingLeft="14dp"
                android:paddingRight="14dp"
                android:layout_width="match_parent"
                android:layout_height="match_parent">
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:contentDescription="@null"
                    app:srcCompat="@drawable/ic_action_image"/>
                <TextView
                    android:textSize="15sp"
                    android:textColor="@color/color_text_primary"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="12dp"
                    android:text="我的空间"
                    android:layout_weight="1"/>
                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:tint="@color/color_text_secondary"
                    android:contentDescription="@null"
                    app:srcCompat="@android:drawable/ic_media_next"/>
            </LinearLayout>
        </com.im.oldchat.ui.widget.TiltFrameLayout>
        <com.im.oldchat.ui.widget.TiltFrameLayout
            android:id="@+id/btnMyFavorites"
            android:background="@drawable/bg_flat_row_selector"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="6dp">
            <LinearLayout
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingLeft="14dp"
                android:paddingRight="14dp"
                android:layout_width="match_parent"
                android:layout_height="match_parent">
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:tint="@color/color_text_secondary"
                    android:contentDescription="@null"
                    app:srcCompat="@drawable/ic_like"/>
                <TextView
                    android:textSize="15sp"
                    android:textColor="@color/color_text_primary"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="12dp"
                    android:text="收藏"
                    android:layout_weight="1"/>
                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:tint="@color/color_text_secondary"
                    android:contentDescription="@null"
                    app:srcCompat="@android:drawable/ic_media_next"/>
            </LinearLayout>
        </com.im.oldchat.ui.widget.TiltFrameLayout>
        <com.im.oldchat.ui.widget.TiltFrameLayout
            android:id="@+id/btnSettings"
            android:background="@drawable/bg_flat_row_selector"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="6dp">
            <LinearLayout
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingLeft="14dp"
                android:paddingRight="14dp"
                android:layout_width="match_parent"
                android:layout_height="match_parent">
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:tint="@color/color_text_secondary"
                    android:contentDescription="@null"
                    app:srcCompat="@drawable/ic_settings"/>
                <TextView
                    android:textSize="15sp"
                    android:textColor="@color/color_text_primary"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="12dp"
                    android:text="设置"
                    android:layout_weight="1"/>
                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:tint="@color/color_text_secondary"
                    android:contentDescription="@null"
                    app:srcCompat="@android:drawable/ic_media_next"/>
            </LinearLayout>
        </com.im.oldchat.ui.widget.TiltFrameLayout>
    </LinearLayout>
</ScrollView>
