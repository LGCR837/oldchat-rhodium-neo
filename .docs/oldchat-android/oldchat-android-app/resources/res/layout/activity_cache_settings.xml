<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/color_background"
    android:scrollbars="none"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:background="@color/color_surface"
            android:padding="12dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <ImageView
                android:id="@+id/btnCacheBack"
                android:padding="6dp"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:tint="@color/color_text_primary"
                app:srcCompat="@drawable/ic_nav_back"/>
            <TextView
                android:textSize="18sp"
                android:textColor="@color/color_text_primary"
                android:id="@+id/tvCacheTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="8dp"
                android:text="缓存管理"/>
        </LinearLayout>
        <LinearLayout
            android:orientation="horizontal"
            android:paddingLeft="16dp"
            android:paddingTop="10dp"
            android:paddingRight="16dp"
            android:paddingBottom="10dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:textSize="14sp"
                android:textColor="@color/color_text_secondary"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="缓存总计"
                android:layout_weight="1"/>
            <TextView
                android:textSize="14sp"
                android:textColor="@color/color_text_primary"
                android:id="@+id/tvCacheTotalSize"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 B"/>
        </LinearLayout>
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:id="@+id/rowImageCache"
            android:background="@drawable/bg_settings_sub_item"
            android:paddingLeft="16dp"
            android:paddingRight="16dp"
            android:layout_width="match_parent"
            android:layout_height="56dp">
            <TextView
                android:textSize="15sp"
                android:textColor="@color/color_text_primary"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="图片缓存"
                android:layout_weight="1"/>
            <TextView
                android:textSize="13sp"
                android:textColor="@color/color_text_secondary"
                android:id="@+id/tvImageCacheSize"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginRight="12dp"
                android:text="0 B"/>
            <TextView
                android:textColor="@color/color_text_primary"
                android:id="@+id/btnClearImageCache"
                android:background="@drawable/flat_button_bg"
                android:paddingLeft="12dp"
                android:paddingTop="6dp"
                android:paddingRight="12dp"
                android:paddingBottom="6dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="清理"/>
        </LinearLayout>
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:id="@+id/rowVoiceCache"
            android:background="@drawable/bg_settings_sub_item"
            android:paddingLeft="16dp"
            android:paddingRight="16dp"
            android:layout_width="match_parent"
            android:layout_height="56dp">
            <TextView
                android:textSize="15sp"
                android:textColor="@color/color_text_primary"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="语音缓存"
                android:layout_weight="1"/>
            <TextView
                android:textSize="13sp"
                android:textColor="@color/color_text_secondary"
                android:id="@+id/tvVoiceCacheSize"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginRight="12dp"
                android:text="0 B"/>
            <TextView
                android:textColor="@color/color_text_primary"
                android:id="@+id/btnClearVoiceCache"
                android:background="@drawable/flat_button_bg"
                android:paddingLeft="12dp"
                android:paddingTop="6dp"
                android:paddingRight="12dp"
                android:paddingBottom="6dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="清理"/>
        </LinearLayout>
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:id="@+id/rowChatCache"
            android:background="@drawable/bg_settings_sub_item"
            android:paddingLeft="16dp"
            android:paddingRight="16dp"
            android:layout_width="match_parent"
            android:layout_height="56dp">
            <TextView
                android:textSize="15sp"
                android:textColor="@color/color_text_primary"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="聊天记录缓存"
                android:layout_weight="1"/>
            <TextView
                android:textSize="13sp"
                android:textColor="@color/color_text_secondary"
                android:id="@+id/tvChatCacheSize"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginRight="12dp"
                android:text="0 B"/>
            <TextView
                android:textColor="@color/color_text_primary"
                android:id="@+id/btnClearChatCache"
                android:background="@drawable/flat_button_bg"
                android:paddingLeft="12dp"
                android:paddingTop="6dp"
                android:paddingRight="12dp"
                android:paddingBottom="6dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="清理"/>
        </LinearLayout>
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:id="@+id/rowFriendCache"
            android:background="@drawable/bg_settings_sub_item"
            android:paddingLeft="16dp"
            android:paddingRight="16dp"
            android:layout_width="match_parent"
            android:layout_height="56dp">
            <TextView
                android:textSize="15sp"
                android:textColor="@color/color_text_primary"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="好友列表缓存"
                android:layout_weight="1"/>
            <TextView
                android:textSize="13sp"
                android:textColor="@color/color_text_secondary"
                android:id="@+id/tvFriendCacheSize"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginRight="12dp"
                android:text="0 B"/>
            <TextView
                android:textColor="@color/color_text_primary"
                android:id="@+id/btnClearFriendCache"
                android:background="@drawable/flat_button_bg"
                android:paddingLeft="12dp"
                android:paddingTop="6dp"
                android:paddingRight="12dp"
                android:paddingBottom="6dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="清理"/>
        </LinearLayout>
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:id="@+id/rowGroupCache"
            android:background="@drawable/bg_settings_sub_item"
            android:paddingLeft="16dp"
            android:paddingRight="16dp"
            android:layout_width="match_parent"
            android:layout_height="56dp">
            <TextView
                android:textSize="15sp"
                android:textColor="@color/color_text_primary"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="群列表缓存"
                android:layout_weight="1"/>
            <TextView
                android:textSize="13sp"
                android:textColor="@color/color_text_secondary"
                android:id="@+id/tvGroupCacheSize"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginRight="12dp"
                android:text="0 B"/>
            <TextView
                android:textColor="@color/color_text_primary"
                android:id="@+id/btnClearGroupCache"
                android:background="@drawable/flat_button_bg"
                android:paddingLeft="12dp"
                android:paddingTop="6dp"
                android:paddingRight="12dp"
                android:paddingBottom="6dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="清理"/>
        </LinearLayout>
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:id="@+id/rowMomentCache"
            android:background="@drawable/bg_settings_sub_item"
            android:paddingLeft="16dp"
            android:paddingRight="16dp"
            android:layout_width="match_parent"
            android:layout_height="56dp">
            <TextView
                android:textSize="15sp"
                android:textColor="@color/color_text_primary"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="动态缓存"
                android:layout_weight="1"/>
            <TextView
                android:textSize="13sp"
                android:textColor="@color/color_text_secondary"
                android:id="@+id/tvMomentCacheSize"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginRight="12dp"
                android:text="0 B"/>
            <TextView
                android:textColor="@color/color_text_primary"
                android:id="@+id/btnClearMomentCache"
                android:background="@drawable/flat_button_bg"
                android:paddingLeft="12dp"
                android:paddingTop="6dp"
                android:paddingRight="12dp"
                android:paddingBottom="6dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="清理"/>
        </LinearLayout>
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:id="@+id/rowRecentCache"
            android:background="@drawable/bg_settings_sub_item"
            android:paddingLeft="16dp"
            android:paddingRight="16dp"
            android:layout_width="match_parent"
            android:layout_height="56dp">
            <TextView
                android:textSize="15sp"
                android:textColor="@color/color_text_primary"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="最近会话缓存"
                android:layout_weight="1"/>
            <TextView
                android:textSize="13sp"
                android:textColor="@color/color_text_secondary"
                android:id="@+id/tvRecentCacheSize"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginRight="12dp"
                android:text="0 B"/>
            <TextView
                android:textColor="@color/color_text_primary"
                android:id="@+id/btnClearRecentCache"
                android:background="@drawable/flat_button_bg"
                android:paddingLeft="12dp"
                android:paddingTop="6dp"
                android:paddingRight="12dp"
                android:paddingBottom="6dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="清理"/>
        </LinearLayout>
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:id="@+id/rowUserCache"
            android:background="@drawable/bg_settings_sub_item"
            android:paddingLeft="16dp"
            android:paddingRight="16dp"
            android:layout_width="match_parent"
            android:layout_height="56dp">
            <TextView
                android:textSize="15sp"
                android:textColor="@color/color_text_primary"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="用户名缓存"
                android:layout_weight="1"/>
            <TextView
                android:textSize="13sp"
                android:textColor="@color/color_text_secondary"
                android:id="@+id/tvUserCacheSize"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginRight="12dp"
                android:text="0 B"/>
            <TextView
                android:textColor="@color/color_text_primary"
                android:id="@+id/btnClearUserCache"
                android:background="@drawable/flat_button_bg"
                android:paddingLeft="12dp"
                android:paddingTop="6dp"
                android:paddingRight="12dp"
                android:paddingBottom="6dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="清理"/>
        </LinearLayout>
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:id="@+id/rowAvatarMetaCache"
            android:background="@drawable/bg_settings_sub_item"
            android:paddingLeft="16dp"
            android:paddingRight="16dp"
            android:layout_width="match_parent"
            android:layout_height="56dp">
            <TextView
                android:textSize="15sp"
                android:textColor="@color/color_text_primary"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="头像映射缓存"
                android:layout_weight="1"/>
            <TextView
                android:textSize="13sp"
                android:textColor="@color/color_text_secondary"
                android:id="@+id/tvAvatarMetaCacheSize"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginRight="12dp"
                android:text="0 B"/>
            <TextView
                android:textColor="@color/color_text_primary"
                android:id="@+id/btnClearAvatarMetaCache"
                android:background="@drawable/flat_button_bg"
                android:paddingLeft="12dp"
                android:paddingTop="6dp"
                android:paddingRight="12dp"
                android:paddingBottom="6dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="清理"/>
        </LinearLayout>
        <View
            android:background="@color/color_background"
            android:layout_width="match_parent"
            android:layout_height="16dp"/>
    </LinearLayout>
</ScrollView>
