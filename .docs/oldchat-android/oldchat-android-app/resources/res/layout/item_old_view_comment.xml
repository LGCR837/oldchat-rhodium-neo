<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:background="@drawable/bg_old_view_detail_card"
    android:paddingLeft="12dp"
    android:paddingTop="10dp"
    android:paddingRight="12dp"
    android:paddingBottom="10dp"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <ImageView
        android:id="@+id/ivOldViewCommentAvatar"
        android:background="@drawable/bg_avatar_round"
        android:layout_width="34dp"
        android:layout_height="34dp"
        android:src="@drawable/ic_avatar_placeholder"
        android:scaleType="centerCrop"
        android:contentDescription="@null"/>
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginLeft="10dp"
        android:layout_weight="1">
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/color_text_primary"
                android:id="@+id/tvOldViewCommentName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
            <TextView
                android:textSize="10sp"
                android:textColor="@color/color_text_secondary"
                android:id="@+id/tvOldViewCommentTag"
                android:background="@drawable/bg_old_view_stat"
                android:paddingLeft="5dp"
                android:paddingTop="1dp"
                android:paddingRight="5dp"
                android:paddingBottom="1dp"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="6dp"/>
        </LinearLayout>
        <TextView
            android:textSize="13sp"
            android:textColor="@color/color_text_primary"
            android:id="@+id/tvOldViewCommentContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"/>
        <TextView
            android:textSize="11sp"
            android:textColor="@color/color_text_secondary"
            android:id="@+id/tvOldViewCommentTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"/>
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp">
            <TextView
                android:textSize="12sp"
                android:textColor="@color/color_text_primary"
                android:gravity="center"
                android:id="@+id/tvOldViewCommentLike"
                android:background="@drawable/bg_old_view_action_inactive"
                android:paddingLeft="6dp"
                android:paddingTop="2dp"
                android:paddingRight="6dp"
                android:paddingBottom="2dp"
                android:layout_width="wrap_content"
                android:layout_height="24dp"/>
            <TextView
                android:textSize="12sp"
                android:textColor="@color/color_text_primary"
                android:gravity="center"
                android:id="@+id/tvOldViewCommentReply"
                android:background="@drawable/bg_old_view_action_inactive"
                android:paddingLeft="6dp"
                android:paddingTop="2dp"
                android:paddingRight="6dp"
                android:paddingBottom="2dp"
                android:layout_width="wrap_content"
                android:layout_height="24dp"
                android:layout_marginLeft="8dp"
                android:text="回复"/>
            <TextView
                android:textSize="11sp"
                android:textColor="@color/color_text_secondary"
                android:id="@+id/tvOldViewCommentReplyCount"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="8dp"/>
        </LinearLayout>
        <TextView
            android:textSize="12sp"
            android:textColor="@color/color_text_secondary"
            android:id="@+id/tvOldViewCommentReplies"
            android:background="@drawable/bg_old_view_detail_topbar"
            android:paddingLeft="8dp"
            android:paddingTop="6dp"
            android:paddingRight="8dp"
            android:paddingBottom="6dp"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:lineSpacingExtra="2dp"/>
        <TextView
            android:textSize="11sp"
            android:textColor="@color/color_on_primary"
            android:gravity="center"
            android:id="@+id/tvOldViewCommentReplyToggle"
            android:background="@drawable/bg_old_view_action_active"
            android:paddingLeft="10dp"
            android:paddingTop="2dp"
            android:paddingRight="10dp"
            android:paddingBottom="2dp"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="24dp"
            android:layout_marginTop="6dp"/>
    </LinearLayout>
</LinearLayout>
