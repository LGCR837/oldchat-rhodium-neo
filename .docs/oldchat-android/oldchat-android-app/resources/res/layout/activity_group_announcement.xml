<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="@color/color_background"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:background="@color/color_surface"
        android:padding="12dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <ImageView
            android:id="@+id/btnGroupAnnouncementBack"
            android:padding="6dp"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_nav_back"
            android:tint="@color/color_text_primary"
            android:contentDescription="@null"/>
        <TextView
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/color_text_primary"
            android:id="@+id/tvGroupAnnouncementPageTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="8dp"
            android:text="群公告"/>
    </LinearLayout>
    <ScrollView
        android:id="@+id/svGroupAnnouncementContent"
        android:scrollbars="none"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:layout_weight="1">
        <LinearLayout
            android:orientation="vertical"
            android:padding="12dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:textSize="13sp"
                android:textColor="@color/color_text_secondary"
                android:id="@+id/tvGroupAnnouncementGroupName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="群聊"/>
            <LinearLayout
                android:gravity="end"
                android:orientation="horizontal"
                android:id="@+id/layoutGroupAnnouncementQuickActions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp">
                <TextView
                    android:textSize="14sp"
                    android:textColor="@color/color_text_primary"
                    android:gravity="center"
                    android:id="@+id/btnGroupAnnouncementArrowUp"
                    android:background="@drawable/flat_button_bg"
                    android:layout_width="34dp"
                    android:layout_height="34dp"
                    android:text="▲"/>
                <TextView
                    android:textSize="13sp"
                    android:textColor="@color/color_text_primary"
                    android:gravity="center"
                    android:id="@+id/btnGroupAnnouncementArrowDown"
                    android:background="@drawable/flat_button_bg"
                    android:layout_width="42dp"
                    android:layout_height="34dp"
                    android:layout_marginLeft="8dp"
                    android:text="▼发"/>
            </LinearLayout>
            <LinearLayout
                android:orientation="vertical"
                android:id="@+id/layoutAnnouncementEditor"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp">
                <TextView
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/color_text_primary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="公告内容"/>
                <EditText
                    android:textColor="@color/color_text_primary"
                    android:textColorHint="@color/color_text_secondary"
                    android:gravity="start|top"
                    android:id="@+id/etGroupAnnouncementContent"
                    android:background="@drawable/flat_input_bg"
                    android:padding="12dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:hint="请输入群公告"
                    android:maxLines="10"
                    android:minLines="8"
                    android:inputType="textMultiLine"/>
                <TextView
                    android:textSize="12sp"
                    android:textColor="@color/color_text_secondary"
                    android:gravity="center"
                    android:id="@+id/viewGroupAnnouncementCursorPad"
                    android:background="@drawable/bg_profile_item"
                    android:paddingLeft="10dp"
                    android:paddingRight="10dp"
                    android:layout_width="match_parent"
                    android:layout_height="34dp"
                    android:layout_marginTop="6dp"
                    android:text="@string/group_announcement_cursor_pad"/>
                <TextView
                    android:textSize="12sp"
                    android:textColor="@color/color_text_secondary"
                    android:gravity="end"
                    android:id="@+id/tvGroupAnnouncementCount"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="0 字"/>
                <TextView
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/color_text_primary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="阅读方式"/>
                <RadioGroup
                    android:orientation="horizontal"
                    android:id="@+id/rgAnnouncementMode"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp">
                    <RadioButton
                        android:textColor="@color/color_text_primary"
                        android:id="@+id/rbAnnouncementOptional"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="选读"/>
                    <RadioButton
                        android:textColor="@color/color_text_primary"
                        android:id="@+id/rbAnnouncementRequired"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="14dp"
                        android:text="必读"/>
                </RadioGroup>
                <TextView
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/color_text_primary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="预览"/>
                <TextView
                    android:textSize="13sp"
                    android:textColor="@color/color_text_secondary"
                    android:id="@+id/tvGroupAnnouncementPreview"
                    android:background="@drawable/bg_profile_item"
                    android:padding="12dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="暂无群公告"/>
            </LinearLayout>
            <LinearLayout
                android:orientation="vertical"
                android:id="@+id/layoutAnnouncementViewer"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp">
                <TextView
                    android:textSize="11sp"
                    android:textColor="@color/color_on_primary"
                    android:id="@+id/tvAnnouncementViewerMode"
                    android:background="@drawable/bg_badge_title"
                    android:paddingLeft="8dp"
                    android:paddingTop="4dp"
                    android:paddingRight="8dp"
                    android:paddingBottom="4dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="选读"/>
                <TextView
                    android:textSize="14sp"
                    android:textColor="@color/color_text_primary"
                    android:id="@+id/tvAnnouncementViewerContent"
                    android:background="@drawable/bg_profile_item"
                    android:padding="12dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="暂无群公告"
                    android:lineSpacingExtra="2dp"/>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
    <LinearLayout
        android:orientation="horizontal"
        android:background="@color/color_surface"
        android:padding="12dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:textSize="14sp"
            android:textColor="@color/color_text_primary"
            android:gravity="center"
            android:id="@+id/btnGroupAnnouncementDelete"
            android:background="@drawable/flat_button_bg"
            android:visibility="gone"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:text="删除"
            android:layout_weight="1"/>
        <TextView
            android:textSize="14sp"
            android:textColor="@color/color_text_primary"
            android:gravity="center"
            android:id="@+id/btnGroupAnnouncementPrimary"
            android:background="@drawable/flat_button_bg"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_marginLeft="10dp"
            android:text="发布公告"
            android:layout_weight="1"/>
    </LinearLayout>
</LinearLayout>
