<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="@color/color_background"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:background="@color/color_surface"
        android:paddingLeft="10dp"
        android:paddingRight="10dp"
        android:layout_width="match_parent"
        android:layout_height="56dp">
        <ImageView
            android:id="@+id/btnMusicDownloadsBack"
            android:background="@drawable/bg_icon_btn"
            android:padding="8dp"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:src="@drawable/ic_nav_back"
            android:contentDescription="@null"/>
        <TextView
            android:textSize="17sp"
            android:textStyle="bold"
            android:textColor="@color/color_text_primary"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginLeft="8dp"
            android:text="我的下载"
            android:layout_weight="1"/>
        <TextView
            android:textSize="12sp"
            android:textColor="@color/color_text_primary"
            android:gravity="center"
            android:id="@+id/btnMusicDownloadsRefresh"
            android:background="@drawable/bg_music_top_chip"
            android:paddingLeft="12dp"
            android:paddingRight="12dp"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:minWidth="56dp"
            android:text="刷新"/>
    </LinearLayout>
    <TextView
        android:textSize="12sp"
        android:textColor="@color/color_text_secondary"
        android:id="@+id/tvMusicDownloadsSummary"
        android:paddingLeft="12dp"
        android:paddingTop="8dp"
        android:paddingRight="12dp"
        android:paddingBottom="6dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>
    <ListView
        android:scrollbarStyle="outsideOverlay"
        android:id="@+id/lvMusicDownloads"
        android:paddingLeft="10dp"
        android:paddingRight="10dp"
        android:paddingBottom="10dp"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:cacheColorHint="@android:color/transparent"
        android:divider="@color/color_divider"
        android:dividerHeight="0.6dp"
        android:layout_weight="1"/>
    <TextView
        android:textSize="13sp"
        android:textColor="@color/color_text_secondary"
        android:gravity="center"
        android:id="@+id/tvMusicDownloadsEmpty"
        android:padding="18dp"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="暂无已下载歌曲"/>
</LinearLayout>
