<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <TextView
        android:textSize="11sp"
        android:textColor="@color/color_text_secondary"
        android:layout_gravity="center_horizontal"
        android:id="@+id/tvMessageTime"
        android:background="@drawable/bg_time_label"
        android:paddingLeft="12dp"
        android:paddingTop="4dp"
        android:paddingRight="12dp"
        android:paddingBottom="4dp"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        android:includeFontPadding="false"/>
    <LinearLayout
        android:orientation="horizontal"
        android:id="@+id/message_container"
        android:padding="4dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <LinearLayout
            android:orientation="vertical"
            android:id="@+id/message_bubble"
            android:padding="10dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            <LinearLayout
                android:orientation="vertical"
                android:id="@+id/quote_container"
                android:background="@drawable/bg_quote_preview"
                android:padding="6dp"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp">
                <TextView
                    android:textSize="12sp"
                    android:textColor="@color/color_text_secondary"
                    android:ellipsize="end"
                    android:id="@+id/tvQuoteSender"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:maxWidth="220dp"
                    android:singleLine="true"
                    android:includeFontPadding="false"/>
                <LinearLayout
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">
                    <ImageView
                        android:id="@+id/ivQuoteImage"
                        android:visibility="gone"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_marginRight="6dp"
                        android:scaleType="centerCrop"
                        android:contentDescription="@null"/>
                    <TextView
                        android:textSize="13sp"
                        android:textColor="@color/color_text_primary"
                        android:id="@+id/tvQuoteContent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:maxWidth="240dp"
                        android:includeFontPadding="false"
                        android:lineSpacingExtra="2dp"/>
                </LinearLayout>
            </LinearLayout>
            <LinearLayout
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:id="@+id/message_text_row"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">
                <TextView
                    android:textSize="16sp"
                    android:textColor="@color/color_text_primary"
                    android:id="@+id/tvMessage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:maxWidth="260dp"
                    android:includeFontPadding="false"
                    android:lineSpacingExtra="2dp"/>
                <LinearLayout
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:id="@+id/message_status_row"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="6dp">
                    <TextView
                        android:textSize="10sp"
                        android:textColor="@color/colorSuccess"
                        android:id="@+id/tvMessageStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="已发送"/>
                    <ImageView
                        android:id="@+id/ivMessageStatus"
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:layout_marginLeft="4dp"
                        android:contentDescription="@null"
                        app:srcCompat="@drawable/ic_msg_sent"/>
                </LinearLayout>
            </LinearLayout>
            <LinearLayout
                android:orientation="vertical"
                android:id="@+id/resource_card"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp">
                <FrameLayout
                    android:id="@+id/flResourceCover"
                    android:visibility="gone"
                    android:layout_width="168dp"
                    android:layout_height="96dp"
                    android:layout_marginBottom="8dp">
                    <com.im.oldchat.ui.widget.RoundedImageView
                        android:id="@+id/ivResourceCover"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:contentDescription="@null"
                        app:cornerRadius="0dp"
                        app:srcCompat="@drawable/bg_image_placeholder"/>
                    <View
                        android:background="#22000000"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"/>
                    <ImageView
                        android:layout_gravity="center"
                        android:id="@+id/ivResourcePlay"
                        android:layout_width="34dp"
                        android:layout_height="34dp"
                        android:tint="@android:color/white"
                        android:contentDescription="@null"
                        app:srcCompat="@drawable/ic_action_video"/>
                </FrameLayout>
                <LinearLayout
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">
                    <ImageView
                        android:id="@+id/ivResourceIcon"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:contentDescription="@null"
                        app:srcCompat="@drawable/ic_document"/>
                    <LinearLayout
                        android:orientation="vertical"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="8dp">
                        <TextView
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="@color/color_text_primary"
                            android:ellipsize="end"
                            android:id="@+id/tvResourceTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:maxWidth="220dp"
                            android:singleLine="true"
                            android:includeFontPadding="false"/>
                        <TextView
                            android:textSize="12sp"
                            android:textColor="@color/color_text_secondary"
                            android:ellipsize="end"
                            android:id="@+id/tvResourceSub"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:maxWidth="220dp"
                            android:singleLine="true"
                            android:includeFontPadding="false"/>
                    </LinearLayout>
                    <TextView
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="?attr/colorPrimary"
                        android:id="@+id/tvResourceAction"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="10dp"
                        android:text="下载"
                        android:includeFontPadding="false"/>
                </LinearLayout>
            </LinearLayout>
            <LinearLayout
                android:orientation="vertical"
                android:id="@+id/red_packet_container"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:minWidth="188dp">
                <LinearLayout
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">
                    <ImageView
                        android:id="@+id/ivRedPacketIcon"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:contentDescription="@null"
                        app:srcCompat="@drawable/ic_red_packet"/>
                    <LinearLayout
                        android:orientation="vertical"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="10dp">
                        <TextView
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="@color/color_on_primary"
                            android:ellipsize="end"
                            android:id="@+id/tvRedPacketTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:maxWidth="220dp"
                            android:singleLine="true"
                            android:includeFontPadding="false"/>
                        <TextView
                            android:textSize="12sp"
                            android:textColor="@color/color_on_primary"
                            android:ellipsize="end"
                            android:id="@+id/tvRedPacketDesc"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:maxWidth="220dp"
                            android:singleLine="true"
                            android:includeFontPadding="false"/>
                    </LinearLayout>
                </LinearLayout>
                <View
                    android:background="#33ffffff"
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="8dp"/>
                <LinearLayout
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp">
                    <TextView
                        android:textSize="11sp"
                        android:textColor="@color/color_on_primary"
                        android:id="@+id/tvRedPacketOpenTip"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="@string/red_packet_open_tip"
                        android:includeFontPadding="false"
                        android:layout_weight="1"/>
                    <ImageView
                        android:id="@+id/ivRedPacketStatus"
                        android:visibility="gone"
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:contentDescription="@null"
                        app:srcCompat="@drawable/ic_msg_sent"/>
                </LinearLayout>
            </LinearLayout>
            <FrameLayout
                android:id="@+id/image_container"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp">
                <com.im.oldchat.ui.widget.RoundedImageView
                    android:id="@+id/ivMessageImage"
                    android:layout_width="180dp"
                    android:layout_height="180dp"
                    android:scaleType="centerCrop"
                    app:cornerRadius="0dp"
                    app:srcCompat="@drawable/ic_avatar_placeholder"/>
                <ProgressBar
                    android:layout_gravity="center"
                    android:id="@+id/pbImageLoading"
                    android:visibility="gone"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:indeterminate="true"
                    style="?android:attr/progressBarStyle"/>
                <ImageView
                    android:layout_gravity="center"
                    android:id="@+id/ivVideoPlay"
                    android:visibility="gone"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:contentDescription="@null"
                    app:srcCompat="@drawable/ic_action_video"/>
            </FrameLayout>
            <LinearLayout
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:id="@+id/voice_row"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp">
                <ImageView
                    android:id="@+id/ivVoiceIcon"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:contentDescription="@null"
                    app:srcCompat="@drawable/ic_voice"/>
                <ProgressBar
                    android:id="@+id/pbVoiceLoading"
                    android:visibility="gone"
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:layout_marginLeft="4dp"
                    android:indeterminate="true"
                    style="@android:style/Widget.ProgressBar.Small"/>
                <TextView
                    android:textSize="14sp"
                    android:textColor="@color/color_text_primary"
                    android:id="@+id/tvVoiceDuration"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="6dp"
                    android:text="1&quot;"/>
            </LinearLayout>
            <TextView
                android:textSize="13sp"
                android:textColor="@color/color_text_primary"
                android:id="@+id/tvVoiceTranscript"
                android:background="@drawable/bg_quote_preview"
                android:paddingLeft="8dp"
                android:paddingTop="5dp"
                android:paddingRight="8dp"
                android:paddingBottom="5dp"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:maxWidth="240dp"
                android:lineSpacingExtra="1dp"/>
            <LinearLayout
                android:gravity="center_vertical"
                android:layout_gravity="right"
                android:orientation="horizontal"
                android:id="@+id/message_status_media_row"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp">
                <TextView
                    android:textSize="10sp"
                    android:textColor="@color/colorSuccess"
                    android:id="@+id/tvMessageStatusMedia"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="已发送"/>
                <ImageView
                    android:id="@+id/ivMessageStatusMedia"
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:layout_marginLeft="4dp"
                    android:contentDescription="@null"
                    app:srcCompat="@drawable/ic_msg_sent"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
