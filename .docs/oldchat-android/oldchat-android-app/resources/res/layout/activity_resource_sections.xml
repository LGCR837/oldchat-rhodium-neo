<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="@color/color_background"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:background="@color/color_surface"
        android:paddingLeft="8dp"
        android:paddingRight="12dp"
        android:layout_width="match_parent"
        android:layout_height="56dp">
        <ImageView
            android:id="@+id/btnResourceSectionsBack"
            android:padding="8dp"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_nav_back"
            android:tint="@color/color_text_primary"
            android:contentDescription="@null"/>
        <TextView
            android:textSize="18sp"
            android:textColor="@color/color_text_primary"
            android:id="@+id/tvResourceSectionsTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginLeft="8dp"
            android:text="资源分享"
            android:layout_weight="1"/>
        <android.support.v7.widget.AppCompatImageView
            android:id="@+id/btnResourceSectionsAdd"
            android:padding="4dp"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:tint="@color/color_text_primary"
            android:contentDescription="@null"
            app:srcCompat="@drawable/icon_chat_plus"/>
    </LinearLayout>
    <ProgressBar
        android:id="@+id/pbResourceSectionsLoading"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:indeterminate="true"
        style="?android:attr/progressBarStyleHorizontal"/>
    <TextView
        android:textSize="12sp"
        android:textColor="@color/color_text_secondary"
        android:id="@+id/tvResourceQuota"
        android:background="@color/color_surface"
        android:paddingLeft="12dp"
        android:paddingTop="10dp"
        android:paddingRight="12dp"
        android:paddingBottom="10dp"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""/>
    <ListView
        android:id="@+id/lvResourceSections"
        android:padding="8dp"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:listSelector="@android:color/transparent"
        android:divider="@android:color/transparent"
        android:dividerHeight="8dp"
        android:layout_weight="1"
        android:overScrollMode="never"/>
</LinearLayout>
