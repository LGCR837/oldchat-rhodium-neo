<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="@color/color_background"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:background="@color/color_surface"
        android:paddingLeft="12dp"
        android:paddingRight="12dp"
        android:layout_width="match_parent"
        android:layout_height="56dp">
        <com.im.oldchat.ui.widget.FontAwesomeTextView
            android:textSize="16sp"
            android:textColor="@color/color_text_primary"
            android:gravity="center"
            android:id="@+id/btnRedPacketOpenBack"
            android:padding="6dp"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:text=""
            android:includeFontPadding="false"
            android:contentDescription="@null"/>
        <TextView
            android:textSize="18sp"
            android:textColor="@color/color_text_primary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="8dp"
            android:text="@string/red_packet_open"/>
    </LinearLayout>
    <LinearLayout
        android:gravity="center"
        android:orientation="vertical"
        android:paddingLeft="16dp"
        android:paddingTop="20dp"
        android:paddingRight="16dp"
        android:paddingBottom="16dp"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">
        <LinearLayout
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:background="@drawable/bg_red_packet_open_card"
            android:paddingLeft="18dp"
            android:paddingTop="20dp"
            android:paddingRight="18dp"
            android:paddingBottom="18dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <ImageView
                android:id="@+id/ivRedPacketOpenIcon"
                android:background="@drawable/bg_red_packet_icon_circle"
                android:padding="14dp"
                android:layout_width="96dp"
                android:layout_height="96dp"
                android:src="@drawable/ic_red_packet"
                android:scaleType="centerCrop"
                android:contentDescription="@null"/>
            <TextView
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/color_text_primary"
                android:ellipsize="end"
                android:gravity="center"
                android:id="@+id/tvRedPacketOpenTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:maxLines="2"/>
            <TextView
                android:textSize="13sp"
                android:textColor="@color/color_text_secondary"
                android:id="@+id/tvRedPacketOpenStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"/>
            <TextView
                android:textSize="12sp"
                android:textColor="@color/color_text_secondary"
                android:gravity="center"
                android:id="@+id/tvRedPacketOpenHint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="点击开启领取红包"/>
            <TextView
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/color_on_primary"
                android:gravity="center"
                android:id="@+id/btnOpenRedPacket"
                android:background="@drawable/bg_red_packet_open_primary"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="16dp"
                android:text="@string/red_packet_open"/>
            <ProgressBar
                android:id="@+id/pbRedPacketOpen"
                android:visibility="gone"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginTop="12dp"
                android:indeterminate="true"/>
            <TextView
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/color_text_primary"
                android:id="@+id/tvRedPacketResult"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"/>
            <TextView
                android:textSize="14sp"
                android:textColor="@color/color_text_primary"
                android:gravity="center"
                android:id="@+id/btnRedPacketDetail"
                android:background="@drawable/bg_red_packet_open_outline"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="42dp"
                android:layout_marginTop="12dp"
                android:text="@string/red_packet_detail_title"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
