<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:id="@+id/layoutOldViewDetailHeaderRoot"
    android:background="@drawable/bg_old_view_detail_card"
    android:paddingLeft="12dp"
    android:paddingTop="12dp"
    android:paddingRight="12dp"
    android:paddingBottom="12dp"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <FrameLayout
        android:id="@+id/layoutOldViewPlayer"
        android:background="@drawable/bg_old_view_player_shell"
        android:padding="1dp"
        android:layout_width="match_parent"
        android:layout_height="204dp">
        <ImageView
            android:id="@+id/ivOldViewDetailCover"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="@null"/>
        <VideoView
            android:id="@+id/vvOldViewPlayer"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>
        <LinearLayout
            android:gravity="center_horizontal"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:id="@+id/layoutOldViewPlayerLoading"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            <ProgressBar
                android:id="@+id/pbOldViewPlayerLoading"
                android:layout_width="28dp"
                android:layout_height="28dp"
                style="?android:attr/progressBarStyle"/>
            <TextView
                android:textSize="12sp"
                android:textColor="@android:color/white"
                android:id="@+id/tvOldViewPlayerHint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="视频加载中..."/>
        </LinearLayout>
        <ImageView
            android:layout_gravity="center"
            android:id="@+id/btnOldViewPlay"
            android:background="@drawable/bg_old_view_control_circle_primary"
            android:padding="14dp"
            android:layout_width="62dp"
            android:layout_height="62dp"
            android:src="@android:drawable/ic_media_play"
            android:contentDescription="@null"/>
        <TextView
            android:textSize="12sp"
            android:textColor="@android:color/white"
            android:layout_gravity="bottom|right"
            android:id="@+id/btnOldViewRetry"
            android:background="@drawable/bg_old_view_player_badge"
            android:paddingLeft="8dp"
            android:paddingTop="4dp"
            android:paddingRight="8dp"
            android:paddingBottom="4dp"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="8dp"
            android:text="重试"/>
        <TextView
            android:textSize="12sp"
            android:textColor="@android:color/white"
            android:layout_gravity="top|right"
            android:id="@+id/btnOldViewFullscreen"
            android:background="@drawable/bg_old_view_player_badge"
            android:paddingLeft="8dp"
            android:paddingTop="4dp"
            android:paddingRight="8dp"
            android:paddingBottom="4dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="8dp"
            android:text="全屏"/>
    </FrameLayout>
    <LinearLayout
        android:gravity="center_vertical"
        android:id="@+id/layoutOldViewOwner"
        android:background="@drawable/bg_old_view_action_inactive"
        android:focusable="true"
        android:clickable="true"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp">
        <ImageView
            android:id="@+id/ivOldViewDetailOwnerAvatar"
            android:background="@drawable/bg_avatar_round"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_avatar_placeholder"
            android:scaleType="centerCrop"
            android:contentDescription="@null"/>
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginLeft="10dp"
            android:layout_weight="1">
            <TextView
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/color_text_primary"
                android:id="@+id/tvOldViewDetailOwnerName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
            <TextView
                android:textSize="11sp"
                android:textColor="@color/color_text_secondary"
                android:id="@+id/tvOldViewDetailOwnerTag"
                android:background="@drawable/bg_old_view_stat"
                android:paddingLeft="6dp"
                android:paddingTop="2dp"
                android:paddingRight="6dp"
                android:paddingBottom="2dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/old_view_owner_tag"/>
        </LinearLayout>
        <TextView
            android:textSize="11sp"
            android:textColor="@color/color_text_secondary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="主页"/>
    </LinearLayout>
    <TextView
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="@color/color_text_primary"
        android:id="@+id/tvOldViewDetailVideoTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"/>
    <TextView
        android:textSize="12sp"
        android:textColor="@color/color_text_secondary"
        android:id="@+id/tvOldViewDetailMeta"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"/>
    <LinearLayout
        android:orientation="horizontal"
        android:id="@+id/layoutOldViewStats"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:weightSum="4">
        <TextView
            android:textSize="12sp"
            android:textColor="@color/color_text_secondary"
            android:gravity="center"
            android:id="@+id/tvOldViewDetailStatPlay"
            android:background="@drawable/bg_old_view_stat"
            android:layout_width="0dp"
            android:layout_height="30dp"
            android:layout_marginRight="4dp"
            android:layout_weight="1"/>
        <TextView
            android:textSize="12sp"
            android:textColor="@color/color_text_secondary"
            android:gravity="center"
            android:id="@+id/tvOldViewDetailStatDanmaku"
            android:background="@drawable/bg_old_view_stat"
            android:layout_width="0dp"
            android:layout_height="30dp"
            android:layout_marginRight="4dp"
            android:layout_weight="1"/>
        <TextView
            android:textSize="12sp"
            android:textColor="@color/color_text_secondary"
            android:gravity="center"
            android:id="@+id/tvOldViewDetailStatReply"
            android:background="@drawable/bg_old_view_stat"
            android:layout_width="0dp"
            android:layout_height="30dp"
            android:layout_marginRight="4dp"
            android:layout_weight="1"/>
        <TextView
            android:textSize="12sp"
            android:textColor="@color/color_text_secondary"
            android:gravity="center"
            android:id="@+id/tvOldViewDetailStatLike"
            android:background="@drawable/bg_old_view_stat"
            android:layout_width="0dp"
            android:layout_height="30dp"
            android:layout_weight="1"/>
    </LinearLayout>
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:id="@+id/layoutOldViewVideoActions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp">
        <TextView
            android:textSize="12sp"
            android:textColor="@color/color_text_primary"
            android:gravity="center"
            android:id="@+id/btnOldViewVideoLike"
            android:background="@drawable/bg_old_view_action_inactive"
            android:paddingLeft="12dp"
            android:paddingRight="12dp"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:minWidth="64dp"
            android:text="点赞"/>
        <TextView
            android:textSize="12sp"
            android:textColor="@color/color_text_primary"
            android:gravity="center"
            android:id="@+id/btnOldViewVideoFavorite"
            android:background="@drawable/bg_old_view_action_inactive"
            android:paddingLeft="12dp"
            android:paddingRight="12dp"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:layout_marginLeft="8dp"
            android:minWidth="64dp"
            android:text="收藏"/>
        <TextView
            android:textSize="11sp"
            android:textColor="@color/color_text_secondary"
            android:ellipsize="end"
            android:id="@+id/tvOldViewVideoActionHint"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginLeft="10dp"
            android:text="支持点赞和收藏"
            android:maxLines="1"
            android:layout_weight="1"/>
    </LinearLayout>
    <TextView
        android:textSize="13sp"
        android:textStyle="bold"
        android:textColor="@color/color_text_primary"
        android:id="@+id/tvOldViewDetailSummaryLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:text="@string/old_view_summary"/>
    <TextView
        android:textSize="13sp"
        android:textColor="@color/color_text_secondary"
        android:ellipsize="end"
        android:id="@+id/tvOldViewDetailDesc"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:maxLines="2"/>
    <View
        android:background="@color/color_divider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="8dp"/>
    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="@color/color_on_primary"
            android:gravity="center"
            android:id="@+id/tabOldViewRelated"
            android:background="@drawable/bg_old_view_tab_active"
            android:layout_width="0dp"
            android:layout_height="34dp"
            android:layout_marginRight="5dp"
            android:text="@string/old_view_related_videos"
            android:layout_weight="1"/>
        <TextView
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="@color/color_text_secondary"
            android:gravity="center"
            android:id="@+id/tabOldViewComments"
            android:background="@drawable/bg_old_view_tab_inactive"
            android:layout_width="0dp"
            android:layout_height="34dp"
            android:layout_marginLeft="5dp"
            android:text="@string/old_view_comments"
            android:layout_weight="1"/>
    </LinearLayout>
</LinearLayout>
