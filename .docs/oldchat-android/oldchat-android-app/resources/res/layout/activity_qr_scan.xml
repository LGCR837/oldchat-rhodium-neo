<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="@color/color_background"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:background="@color/color_surface"
        android:paddingLeft="12dp"
        android:paddingRight="16dp"
        android:layout_width="match_parent"
        android:layout_height="56dp">
        <ImageView
            android:id="@+id/btnQrScanBack"
            android:padding="6dp"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_nav_back"
            android:tint="@color/color_text_primary"
            android:contentDescription="@null"/>
        <TextView
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/color_text_primary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="8dp"
            android:text="扫码识别"/>
    </LinearLayout>
    <LinearLayout
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="18dp"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <ImageView
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:layout_marginTop="16dp"
            android:src="@android:drawable/ic_menu_camera"
            android:tint="?attr/colorPrimary"
            android:contentDescription="@null"/>
        <TextView
            android:textSize="15sp"
            android:textColor="@color/color_text_primary"
            android:gravity="center"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="扫描群二维码可入群，扫描用户名片可加好友"/>
        <Button
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="@color/color_on_primary"
            android:id="@+id/btnScanFromCamera"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="20dp"
            android:text="拍照扫码"
            style="@style/FlatButtonPrimary"/>
        <Button
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="@color/color_on_primary"
            android:id="@+id/btnScanFromGallery"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="10dp"
            android:text="从相册选择二维码"
            style="@style/FlatButtonPrimary"/>
        <TextView
            android:textSize="13sp"
            android:textColor="@color/color_text_secondary"
            android:gravity="center"
            android:id="@+id/tvQrScanHint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="扫码成功后会自动返回并执行"/>
    </LinearLayout>
</LinearLayout>
