<?xml version="1.0" encoding="utf-8"?>
<com.im.oldchat.ui.widget.TiltFrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="@drawable/bg_tab_item"
    android:paddingTop="5dp"
    android:paddingBottom="5dp"
    android:focusable="true"
    android:clickable="true"
    android:layout_width="wrap_content"
    android:layout_height="match_parent">
    <LinearLayout
        android:gravity="center"
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <View
            android:id="@+id/tabIndicator"
            android:background="@color/color_tab_indicator"
            android:visibility="invisible"
            android:layout_width="16dp"
            android:layout_height="2dp"/>
        <FrameLayout
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginTop="4dp">
            <android.support.v7.widget.AppCompatImageView
                android:layout_gravity="center"
                android:id="@+id/tabIcon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="@null"/>
            <View
                android:layout_gravity="top|right"
                android:id="@+id/tabBadge"
                android:background="@drawable/badge_red_dot"
                android:visibility="gone"
                android:layout_width="8dp"
                android:layout_height="8dp"/>
        </FrameLayout>
        <TextView
            android:textSize="11sp"
            android:textColor="@color/tab_icon_tint"
            android:id="@+id/tabLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"/>
    </LinearLayout>
</com.im.oldchat.ui.widget.TiltFrameLayout>
