<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:background="@drawable/bg_flat_row_selector"
    android:paddingLeft="12dp"
    android:paddingTop="10dp"
    android:paddingRight="12dp"
    android:paddingBottom="10dp"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:minHeight="64dp">
    <com.im.oldchat.ui.widget.RoundedImageView
        android:id="@+id/ivAvatar"
        android:background="@drawable/bg_avatar_round"
        android:layout_width="42dp"
        android:layout_height="42dp"
        android:layout_marginRight="12dp"
        android:scaleType="centerCrop"
        android:contentDescription="@null"
        app:cornerRadius="0dp"
        app:srcCompat="@drawable/ic_avatar_placeholder"/>
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1">
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            <TextView
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/color_text_primary"
                android:ellipsize="end"
                android:id="@+id/tvTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxLines="1"/>
            <TextView
                android:textSize="10sp"
                android:textColor="@color/color_on_primary"
                android:id="@+id/tvRoleBadge"
                android:background="@drawable/bg_badge_owner"
                android:paddingLeft="4dp"
                android:paddingTop="1dp"
                android:paddingRight="4dp"
                android:paddingBottom="1dp"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="6dp"
                android:text="群主"
                android:includeFontPadding="false"/>
            <TextView
                android:textSize="10sp"
                android:textColor="@color/color_on_primary"
                android:ellipsize="end"
                android:id="@+id/tvTitleBadge"
                android:background="@drawable/bg_badge_title"
                android:paddingLeft="4dp"
                android:paddingTop="1dp"
                android:paddingRight="4dp"
                android:paddingBottom="1dp"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="6dp"
                android:text="头衔"
                android:maxLines="1"
                android:includeFontPadding="false"/>
        </LinearLayout>
        <TextView
            android:textSize="12sp"
            android:textColor="@color/color_text_secondary"
            android:id="@+id/tvSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"/>
    </LinearLayout>
    <TextView
        android:textSize="12sp"
        android:textColor="?attr/colorPrimary"
        android:id="@+id/btnAdmin"
        android:background="@drawable/button_outline_primary"
        android:paddingLeft="9dp"
        android:paddingTop="6dp"
        android:paddingRight="9dp"
        android:paddingBottom="6dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="8dp"
        android:text="设为管理员"/>
    <TextView
        android:textSize="12sp"
        android:textColor="@color/colorDanger"
        android:id="@+id/btnKick"
        android:background="@drawable/button_outline_danger"
        android:paddingLeft="9dp"
        android:paddingTop="6dp"
        android:paddingRight="9dp"
        android:paddingBottom="6dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="6dp"
        android:text="移除"/>
</LinearLayout>
