<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="@color/color_background"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:background="@color/color_surface"
        android:paddingLeft="8dp"
        android:paddingRight="12dp"
        android:layout_width="match_parent"
        android:layout_height="56dp">
        <ImageView
            android:id="@+id/btnOldViewBack"
            android:padding="8dp"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_nav_back"
            android:contentDescription="@null"/>
        <TextView
            android:textSize="18sp"
            android:textColor="@color/color_text_primary"
            android:id="@+id/tvOldViewTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginLeft="8dp"
            android:text="@string/old_view_title"
            android:layout_weight="1"/>
        <ImageView
            android:id="@+id/btnOldViewSearch"
            android:padding="8dp"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginRight="4dp"
            android:src="@android:drawable/ic_menu_search"
            android:contentDescription="@null"/>
        <ImageView
            android:id="@+id/btnOldViewMenu"
            android:padding="8dp"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_more"
            android:contentDescription="@null"/>
    </LinearLayout>
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/panelOldViewQuick"
        android:background="@drawable/bg_profile_item"
        android:paddingLeft="10dp"
        android:paddingTop="10dp"
        android:paddingRight="10dp"
        android:paddingBottom="10dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="12dp"
        android:layout_marginTop="10dp"
        android:layout_marginRight="12dp">
        <TextView
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="@color/color_text_primary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/old_view_quick_title"/>
        <TextView
            android:textSize="11sp"
            android:textColor="@color/color_text_secondary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="@string/old_view_quick_hint"/>
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp">
            <TextView
                android:textSize="12sp"
                android:textColor="@color/color_text_primary"
                android:gravity="center"
                android:id="@+id/btnOldViewQuickSearch"
                android:background="@drawable/bg_flat_row_selector"
                android:layout_width="0dp"
                android:layout_height="32dp"
                android:text="@string/old_view_action_search"
                android:layout_weight="1"/>
            <TextView
                android:textSize="12sp"
                android:textColor="@color/color_text_primary"
                android:gravity="center"
                android:id="@+id/btnOldViewQuickHistory"
                android:background="@drawable/bg_flat_row_selector"
                android:layout_width="0dp"
                android:layout_height="32dp"
                android:layout_marginLeft="8dp"
                android:text="@string/old_view_action_history"
                android:layout_weight="1"/>
            <TextView
                android:textSize="12sp"
                android:textColor="@color/color_text_primary"
                android:gravity="center"
                android:id="@+id/btnOldViewQuickFavorites"
                android:background="@drawable/bg_flat_row_selector"
                android:layout_width="0dp"
                android:layout_height="32dp"
                android:layout_marginLeft="8dp"
                android:text="@string/old_view_action_favorites"
                android:layout_weight="1"/>
        </LinearLayout>
    </LinearLayout>
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/panelOldViewLogin"
        android:background="@drawable/bg_profile_item"
        android:paddingLeft="12dp"
        android:paddingTop="12dp"
        android:paddingRight="12dp"
        android:paddingBottom="12dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="12dp"
        android:layout_marginTop="10dp"
        android:layout_marginRight="12dp"
        android:layout_marginBottom="8dp">
        <TextView
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/color_text_primary"
            android:id="@+id/tvOldViewLoginTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/old_view_login_title"/>
        <ImageView
            android:layout_gravity="center_horizontal"
            android:id="@+id/ivOldViewQr"
            android:background="@color/color_surface"
            android:layout_width="180dp"
            android:layout_height="180dp"
            android:layout_marginTop="12dp"
            android:scaleType="centerInside"
            android:contentDescription="@null"/>
        <TextView
            android:textSize="12sp"
            android:textColor="@color/color_text_secondary"
            android:id="@+id/tvOldViewStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/old_view_status_fetch_qr"/>
        <Button
            android:textSize="13sp"
            android:textColor="@color/color_on_primary"
            android:id="@+id/btnOldViewRefresh"
            android:background="@drawable/bg_primary_button"
            android:paddingLeft="16dp"
            android:paddingRight="16dp"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_marginTop="8dp"
            android:text="@string/old_view_action_refresh_qr"/>
    </LinearLayout>
    <ProgressBar
        android:id="@+id/pbOldViewLoading"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:indeterminate="true"
        style="?android:attr/progressBarStyleHorizontal"/>
    <TextView
        android:textSize="13sp"
        android:textColor="@color/color_text_secondary"
        android:gravity="center"
        android:id="@+id/tvOldViewEmpty"
        android:padding="16dp"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/old_view_empty"/>
    <ListView
        android:id="@+id/lvOldViewVideos"
        android:paddingLeft="12dp"
        android:paddingRight="12dp"
        android:paddingBottom="12dp"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:listSelector="@android:color/transparent"
        android:divider="@android:color/transparent"
        android:dividerHeight="8dp"
        android:layout_weight="1"
        android:overScrollMode="never"/>
</LinearLayout>
