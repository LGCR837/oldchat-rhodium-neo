<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="@color/color_background"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:background="@color/color_surface"
        android:paddingLeft="8dp"
        android:paddingRight="12dp"
        android:layout_width="match_parent"
        android:layout_height="56dp">
        <ImageView
            android:id="@+id/btnResourceSectionBack"
            android:padding="8dp"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_nav_back"
            android:tint="@color/color_text_primary"
            android:contentDescription="@null"/>
        <TextView
            android:textSize="18sp"
            android:textColor="@color/color_text_primary"
            android:id="@+id/tvResourceSectionTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginLeft="8dp"
            android:text="资源分区"
            android:layout_weight="1"/>
        <android.support.v7.widget.AppCompatImageView
            android:id="@+id/btnResourceUpload"
            android:padding="4dp"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:tint="@color/color_text_primary"
            android:contentDescription="@null"
            app:srcCompat="@drawable/icon_chat_plus"/>
    </LinearLayout>
    <ProgressBar
        android:id="@+id/pbResourcesLoading"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:indeterminate="true"
        style="?android:attr/progressBarStyleHorizontal"/>
    <TextView
        android:textSize="12sp"
        android:textColor="@color/color_text_secondary"
        android:id="@+id/tvResourceQuota"
        android:background="@color/color_surface"
        android:paddingLeft="12dp"
        android:paddingTop="10dp"
        android:paddingRight="12dp"
        android:paddingBottom="10dp"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""/>
    <LinearLayout
        android:orientation="horizontal"
        android:id="@+id/layoutResourceSearch"
        android:background="@color/color_surface"
        android:paddingLeft="12dp"
        android:paddingTop="8dp"
        android:paddingRight="12dp"
        android:paddingBottom="8dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <EditText
            android:id="@+id/etResourceSearch"
            android:background="@drawable/bg_chat_input"
            android:padding="10dp"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="搜索资源..."
            android:singleLine="true"
            android:layout_weight="1"/>
        <Button
            android:id="@+id/btnResourceSearch"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="8dp"
            android:minWidth="64dp"
            android:text="搜索"/>
    </LinearLayout>
    <ListView
        android:id="@+id/lvResources"
        android:padding="8dp"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:listSelector="@android:color/transparent"
        android:divider="@android:color/transparent"
        android:dividerHeight="8dp"
        android:layout_weight="1"
        android:overScrollMode="never"/>
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/layoutResourceUploadProgress"
        android:background="@color/color_surface"
        android:paddingLeft="12dp"
        android:paddingTop="8dp"
        android:paddingRight="12dp"
        android:paddingBottom="8dp"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:textSize="14sp"
            android:textColor="@color/color_text_primary"
            android:id="@+id/tvResourceUploadStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="正在上传..."/>
        <ProgressBar
            android:id="@+id/pbResourceUpload"
            android:layout_width="match_parent"
            android:layout_height="4dp"
            android:layout_marginTop="6dp"
            android:max="100"
            android:progress="0"
            android:indeterminate="true"
            style="?android:attr/progressBarStyleHorizontal"/>
    </LinearLayout>
</LinearLayout>
