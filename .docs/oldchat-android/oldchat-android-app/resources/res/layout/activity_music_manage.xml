<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="@color/color_background"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:background="@color/color_surface"
        android:paddingLeft="12dp"
        android:paddingRight="12dp"
        android:layout_width="match_parent"
        android:layout_height="56dp">
        <ImageView
            android:id="@+id/btnMusicManageBack"
            android:background="@drawable/bg_music_top_chip"
            android:padding="8dp"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:src="@drawable/ic_nav_back"
            android:contentDescription="@null"/>
        <TextView
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/color_text_primary"
            android:id="@+id/tvMusicManageTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginLeft="8dp"
            android:text="我的上传管理"
            android:layout_weight="1"/>
        <TextView
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="@color/colorDanger"
            android:gravity="center"
            android:id="@+id/btnMusicManageBatchDelete"
            android:background="@drawable/bg_music_action_delete"
            android:paddingLeft="12dp"
            android:paddingRight="12dp"
            android:layout_width="wrap_content"
            android:layout_height="34dp"
            android:minWidth="78dp"
            android:text="删本页"/>
    </LinearLayout>
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:background="@drawable/bg_music_plaza_card_selector"
        android:padding="8dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="12dp"
        android:layout_marginTop="10dp"
        android:layout_marginRight="12dp">
        <EditText
            android:textColor="@color/color_text_primary"
            android:textColorHint="@color/color_text_secondary"
            android:id="@+id/etMusicManageKeyword"
            android:background="@drawable/bg_search_field"
            android:paddingLeft="10dp"
            android:paddingRight="10dp"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:hint="搜索我的歌曲"
            android:singleLine="true"
            android:layout_weight="1"
            android:imeOptions="actionSearch"/>
        <TextView
            android:textSize="14sp"
            android:textColor="@color/color_on_primary"
            android:gravity="center"
            android:id="@+id/btnMusicManageSearch"
            android:background="@drawable/bg_music_top_chip_primary"
            android:paddingLeft="14dp"
            android:paddingRight="14dp"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:layout_marginLeft="8dp"
            android:minWidth="64dp"
            android:text="查找"/>
    </LinearLayout>
    <TextView
        android:textSize="12sp"
        android:textColor="@color/color_text_secondary"
        android:id="@+id/tvMusicManageSummary"
        android:paddingLeft="14dp"
        android:paddingTop="8dp"
        android:paddingRight="14dp"
        android:paddingBottom="4dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""/>
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingLeft="14dp"
        android:paddingRight="14dp"
        android:paddingBottom="6dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:textSize="12sp"
            android:textColor="@color/color_text_secondary"
            android:ellipsize="end"
            android:id="@+id/tvMusicManagePageInfo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text=""
            android:singleLine="true"
            android:layout_weight="1"/>
        <TextView
            android:textSize="12sp"
            android:textColor="@color/color_text_primary"
            android:gravity="center"
            android:id="@+id/btnMusicManagePrev"
            android:background="@drawable/bg_music_top_chip"
            android:paddingLeft="10dp"
            android:paddingRight="10dp"
            android:layout_width="wrap_content"
            android:layout_height="30dp"
            android:minWidth="52dp"
            android:text="上一页"/>
        <TextView
            android:textSize="12sp"
            android:textColor="@color/color_text_primary"
            android:gravity="center"
            android:id="@+id/btnMusicManageNext"
            android:background="@drawable/bg_music_top_chip"
            android:paddingLeft="10dp"
            android:paddingRight="10dp"
            android:layout_width="wrap_content"
            android:layout_height="30dp"
            android:layout_marginLeft="8dp"
            android:minWidth="52dp"
            android:text="下一页"/>
    </LinearLayout>
    <FrameLayout
        android:background="@drawable/bg_list_item_surface"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginLeft="10dp"
        android:layout_marginRight="10dp"
        android:layout_marginBottom="10dp"
        android:layout_weight="1">
        <ListView
            android:id="@+id/lvMusicManage"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:clipToPadding="false"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:listSelector="@android:color/transparent"
            android:divider="@android:color/transparent"
            android:dividerHeight="0dp"/>
        <TextView
            android:textSize="14sp"
            android:textColor="@color/color_text_secondary"
            android:gravity="center"
            android:layout_gravity="center"
            android:id="@+id/tvMusicManageEmpty"
            android:padding="24dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="你还没有上传歌曲"/>
    </FrameLayout>
</LinearLayout>
