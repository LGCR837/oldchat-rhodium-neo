<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:id="@+id/rowRoundedButtons"
        android:background="@drawable/bg_settings_sub_item"
        android:paddingLeft="16dp"
        android:paddingRight="16dp"
        android:layout_width="match_parent"
        android:layout_height="48dp">
        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:tint="@color/color_text_secondary"
            app:srcCompat="@drawable/ic_settings"/>
        <TextView
            android:textSize="15sp"
            android:textColor="@color/color_text_primary"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginLeft="12dp"
            android:text="圆角按钮"
            android:layout_weight="1"/>
        <android.support.v7.widget.SwitchCompat
            android:id="@+id/switchRoundedButtons"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </LinearLayout>
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:id="@+id/rowButton3dEffect"
        android:background="@drawable/bg_settings_sub_item"
        android:paddingLeft="16dp"
        android:paddingRight="16dp"
        android:layout_width="match_parent"
        android:layout_height="48dp">
        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:tint="@color/color_text_secondary"
            app:srcCompat="@drawable/ic_settings"/>
        <TextView
            android:textSize="15sp"
            android:textColor="@color/color_text_primary"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginLeft="12dp"
            android:text="3D按压动效"
            android:layout_weight="1"/>
        <android.support.v7.widget.SwitchCompat
            android:id="@+id/switchButton3dEffect"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </LinearLayout>
</LinearLayout>
