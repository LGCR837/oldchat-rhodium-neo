<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="4dp"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <FrameLayout
        android:id="@+id/typingAvatarStack"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:layout_width="wrap_content"
        android:layout_height="36dp"
        android:layout_marginRight="6dp">
        <com.im.oldchat.ui.widget.RoundedImageView
            android:layout_gravity="center"
            android:id="@+id/ivTypingAvatar"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:contentDescription="@null"/>
        <com.im.oldchat.ui.widget.RoundedImageView
            android:layout_gravity="center"
            android:id="@+id/ivTypingAvatar2"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginLeft="16dp"
            android:contentDescription="@null"/>
        <com.im.oldchat.ui.widget.RoundedImageView
            android:layout_gravity="center"
            android:id="@+id/ivTypingAvatar3"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginLeft="32dp"
            android:contentDescription="@null"/>
    </FrameLayout>
    <LinearLayout
        android:gravity="center"
        android:orientation="horizontal"
        android:id="@+id/typingBubble"
        android:background="@drawable/bg_msg_other"
        android:paddingLeft="12dp"
        android:paddingTop="16dp"
        android:paddingRight="12dp"
        android:paddingBottom="16dp"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:minHeight="40dp">
        <LinearLayout
            android:orientation="horizontal"
            android:id="@+id/typingDots"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            <View
                android:id="@+id/typingDot1"
                android:background="@drawable/bg_typing_dot"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:layout_marginRight="4dp"/>
            <View
                android:id="@+id/typingDot2"
                android:background="@drawable/bg_typing_dot"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:layout_marginRight="4dp"/>
            <View
                android:id="@+id/typingDot3"
                android:background="@drawable/bg_typing_dot"
                android:layout_width="8dp"
                android:layout_height="8dp"/>
        </LinearLayout>
        <TextView
            android:textSize="16sp"
            android:textColor="@color/color_text_primary"
            android:id="@+id/tvTypingText"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="2dp"
            android:includeFontPadding="false"/>
    </LinearLayout>
</LinearLayout>
