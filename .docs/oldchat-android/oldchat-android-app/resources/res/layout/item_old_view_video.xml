<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:background="@drawable/bg_old_view_detail_card"
    android:paddingLeft="12dp"
    android:paddingTop="10dp"
    android:paddingRight="12dp"
    android:paddingBottom="10dp"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <FrameLayout
        android:background="@drawable/bg_old_view_player_shell"
        android:padding="1dp"
        android:layout_width="132dp"
        android:layout_height="74dp">
        <ImageView
            android:id="@+id/ivOldViewCover"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@android:drawable/ic_media_play"
            android:scaleType="centerCrop"
            android:contentDescription="@null"/>
        <ImageView
            android:layout_gravity="center"
            android:background="@drawable/bg_old_view_player_badge"
            android:padding="4dp"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@android:drawable/ic_media_play"
            android:contentDescription="@null"/>
        <TextView
            android:textSize="10sp"
            android:textColor="@android:color/white"
            android:layout_gravity="bottom|right"
            android:id="@+id/tvOldViewDuration"
            android:background="@drawable/bg_old_view_player_badge"
            android:paddingLeft="4dp"
            android:paddingTop="1dp"
            android:paddingRight="4dp"
            android:paddingBottom="1dp"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="4dp"/>
    </FrameLayout>
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginLeft="12dp"
        android:layout_weight="1">
        <TextView
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="@color/color_text_primary"
            android:ellipsize="end"
            android:id="@+id/tvOldViewTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxLines="2"/>
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp">
            <TextView
                android:textSize="12sp"
                android:textColor="@color/color_text_secondary"
                android:ellipsize="end"
                android:id="@+id/tvOldViewUpName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:maxLines="1"
                android:layout_weight="1"/>
            <TextView
                android:textSize="11sp"
                android:textColor="@color/color_text_primary"
                android:gravity="center"
                android:id="@+id/btnOldViewUpProfile"
                android:background="@drawable/bg_old_view_action_inactive"
                android:paddingLeft="8dp"
                android:paddingRight="8dp"
                android:layout_width="wrap_content"
                android:layout_height="26dp"
                android:layout_marginLeft="6dp"
                android:text="@string/old_view_action_up_profile"/>
        </LinearLayout>
        <TextView
            android:textSize="11sp"
            android:textColor="@color/color_text_secondary"
            android:ellipsize="end"
            android:id="@+id/tvOldViewMeta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:maxLines="2"/>
    </LinearLayout>
</LinearLayout>
