<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="@drawable/bg_profile_item"
    android:padding="10dp"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <TextView
        android:textSize="12sp"
        android:textColor="@color/color_text_secondary"
        android:id="@+id/tvStatementUploadHint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:text="可附加截图证据，支持多张"/>
    <EditText
        android:id="@+id/etStatementReason"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:hint="陈述理由"
        android:maxLines="4"
        android:minLines="2"/>
    <EditText
        android:id="@+id/etStatementEvidence"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:hint="证据（聊天记录、时间、截图描述等）"
        android:maxLines="6"
        android:minLines="3"/>
    <TextView
        android:textSize="12sp"
        android:textColor="@color/color_text_primary"
        android:gravity="center"
        android:id="@+id/btnPickEvidence"
        android:background="@drawable/flat_button_bg"
        android:paddingLeft="12dp"
        android:paddingRight="12dp"
        android:layout_width="wrap_content"
        android:layout_height="36dp"
        android:layout_marginTop="10dp"
        android:text="上传截图证据"/>
    <TextView
        android:textSize="12sp"
        android:textColor="@color/color_text_secondary"
        android:id="@+id/tvEvidenceUploadStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"/>
</LinearLayout>
