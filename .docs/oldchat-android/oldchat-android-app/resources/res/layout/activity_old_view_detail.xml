<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="@drawable/bg_old_view_detail_page"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:background="@drawable/bg_old_view_detail_topbar"
        android:paddingLeft="10dp"
        android:paddingRight="12dp"
        android:layout_width="match_parent"
        android:layout_height="58dp">
        <ImageView
            android:id="@+id/btnOldViewDetailBack"
            android:background="@drawable/bg_old_view_control_circle"
            android:padding="8dp"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:src="@drawable/ic_nav_back"
            android:contentDescription="@null"/>
        <TextView
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/color_text_primary"
            android:id="@+id/tvOldViewDetailTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginLeft="10dp"
            android:text="@string/old_view_detail_title"
            android:layout_weight="1"/>
        <ImageView
            android:id="@+id/btnOldViewDetailShare"
            android:background="@drawable/bg_old_view_control_circle"
            android:padding="8dp"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:layout_marginLeft="8dp"
            android:src="@android:drawable/ic_menu_share"
            android:contentDescription="@null"/>
    </LinearLayout>
    <ProgressBar
        android:id="@+id/pbOldViewDetailLoading"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:indeterminate="true"
        style="?android:attr/progressBarStyleHorizontal"/>
    <TextView
        android:textSize="13sp"
        android:textColor="@color/color_text_secondary"
        android:gravity="center"
        android:id="@+id/tvOldViewDetailEmpty"
        android:background="@drawable/bg_old_view_detail_card"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="12dp"
        android:layout_marginTop="10dp"
        android:layout_marginRight="12dp"
        android:text="@string/old_view_comments_empty"/>
    <ListView
        android:id="@+id/lvOldViewDetailComments"
        android:background="@android:color/transparent"
        android:paddingLeft="12dp"
        android:paddingTop="12dp"
        android:paddingRight="12dp"
        android:paddingBottom="8dp"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:listSelector="@android:color/transparent"
        android:cacheColorHint="@android:color/transparent"
        android:divider="@android:color/transparent"
        android:dividerHeight="8dp"
        android:layout_weight="1"
        android:overScrollMode="never"/>
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:id="@+id/layoutOldViewCommentInput"
        android:background="@drawable/bg_old_view_detail_card"
        android:paddingLeft="12dp"
        android:paddingTop="8dp"
        android:paddingRight="12dp"
        android:paddingBottom="8dp"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <EditText
            android:textSize="14sp"
            android:textColor="@color/color_text_primary"
            android:id="@+id/etOldViewComment"
            android:background="@drawable/bg_search_field"
            android:paddingLeft="12dp"
            android:paddingRight="12dp"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:hint="@string/old_view_comment_hint"
            android:singleLine="true"
            android:layout_weight="1"
            android:imeOptions="actionSend"/>
        <TextView
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="@color/color_on_primary"
            android:gravity="center"
            android:id="@+id/btnOldViewCommentSend"
            android:background="@drawable/bg_old_view_action_active"
            android:layout_width="72dp"
            android:layout_height="34dp"
            android:layout_marginLeft="8dp"
            android:text="@string/old_view_comment_send"/>
    </LinearLayout>
</LinearLayout>
