<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="@color/color_background"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:orientation="vertical"
        android:paddingLeft="10dp"
        android:paddingTop="10dp"
        android:paddingRight="10dp"
        android:paddingBottom="8dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <ImageView
                android:id="@+id/btnMusicPlazaBack"
                android:background="@drawable/bg_icon_btn"
                android:padding="8dp"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:src="@drawable/ic_nav_back"
                android:contentDescription="@null"/>
            <LinearLayout
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:background="@drawable/bg_music_plaza_card_selector"
                android:paddingLeft="6dp"
                android:paddingTop="3dp"
                android:paddingRight="6dp"
                android:paddingBottom="3dp"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginLeft="8dp"
                android:layout_weight="1">
                <EditText
                    android:textSize="14sp"
                    android:textColor="@color/color_text_primary"
                    android:textColorHint="@color/color_text_secondary"
                    android:id="@+id/etMusicPlazaKeyword"
                    android:background="@drawable/bg_search_field"
                    android:paddingLeft="8dp"
                    android:paddingTop="7dp"
                    android:paddingRight="8dp"
                    android:paddingBottom="7dp"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:minHeight="36dp"
                    android:hint="搜索歌曲 / 上传者"
                    android:singleLine="true"
                    android:layout_weight="1"
                    android:imeOptions="actionSearch"/>
                <TextView
                    android:textSize="12sp"
                    android:textColor="@color/color_text_primary"
                    android:gravity="center"
                    android:id="@+id/btnMusicPlazaSearch"
                    android:background="@drawable/bg_music_top_chip"
                    android:paddingLeft="10dp"
                    android:paddingRight="10dp"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:layout_marginLeft="6dp"
                    android:minWidth="56dp"
                    android:text="搜索"/>
            </LinearLayout>
        </LinearLayout>
        <HorizontalScrollView
            android:scrollbars="none"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:overScrollMode="never">
            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">
                <TextView
                    android:textSize="12sp"
                    android:textColor="@color/color_text_primary"
                    android:gravity="center"
                    android:id="@+id/btnMusicPlazaNowPlaying"
                    android:background="@drawable/bg_music_top_chip"
                    android:paddingLeft="12dp"
                    android:paddingRight="12dp"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:minWidth="72dp"
                    android:text="正在播放"/>
                <TextView
                    android:textSize="12sp"
                    android:textColor="@color/color_text_primary"
                    android:gravity="center"
                    android:id="@+id/btnMusicPlazaDownloads"
                    android:background="@drawable/bg_music_top_chip"
                    android:paddingLeft="12dp"
                    android:paddingRight="12dp"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:layout_marginLeft="8dp"
                    android:minWidth="72dp"
                    android:text="我的下载"/>
                <TextView
                    android:textSize="12sp"
                    android:textColor="@color/color_on_primary"
                    android:gravity="center"
                    android:id="@+id/btnMusicPlazaUpload"
                    android:background="@drawable/bg_music_top_chip_primary"
                    android:paddingLeft="12dp"
                    android:paddingRight="12dp"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:layout_marginLeft="8dp"
                    android:minWidth="58dp"
                    android:text="我的"/>
            </LinearLayout>
        </HorizontalScrollView>
    </LinearLayout>
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:layout_weight="1">
        <LinearLayout
            android:orientation="vertical"
            android:paddingLeft="10dp"
            android:paddingRight="10dp"
            android:paddingBottom="10dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:textSize="12sp"
                android:textColor="@color/color_text_secondary"
                android:id="@+id/tvMusicPlazaSummary"
                android:paddingTop="2dp"
                android:paddingBottom="6dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""/>
            <TextView
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/color_text_primary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="推荐歌曲"/>
            <LinearLayout
                android:orientation="vertical"
                android:id="@+id/layoutMusicPlazaRecommendRows"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"/>
            <TextView
                android:textSize="12sp"
                android:textColor="@color/color_text_secondary"
                android:gravity="center"
                android:id="@+id/tvMusicPlazaRecommendEmpty"
                android:padding="10dp"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="暂无推荐歌曲"/>
            <TextView
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/color_text_primary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="播放量排行"/>
            <HorizontalScrollView
                android:scrollbars="none"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:overScrollMode="never">
                <LinearLayout
                    android:orientation="horizontal"
                    android:id="@+id/layoutMusicPlazaRankingSongs"
                    android:paddingBottom="2dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </HorizontalScrollView>
            <TextView
                android:textSize="12sp"
                android:textColor="@color/color_text_secondary"
                android:gravity="center"
                android:id="@+id/tvMusicPlazaRankingEmpty"
                android:padding="10dp"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="暂无排行歌曲"/>
            <TextView
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/color_text_primary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="最新歌曲（右滑）"/>
            <HorizontalScrollView
                android:id="@+id/hsvMusicPlazaAllSongs"
                android:scrollbars="none"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp">
                <LinearLayout
                    android:orientation="horizontal"
                    android:id="@+id/layoutMusicPlazaAllSongs"
                    android:paddingBottom="2dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </HorizontalScrollView>
            <TextView
                android:textSize="12sp"
                android:textColor="@color/color_text_secondary"
                android:gravity="center"
                android:id="@+id/tvMusicPlazaAllEmpty"
                android:padding="10dp"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="暂无歌曲"/>
            <TextView
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/color_on_primary"
                android:gravity="center"
                android:id="@+id/btnMusicPlazaOpenAllList"
                android:background="@drawable/bg_music_top_chip_primary"
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:layout_marginTop="10dp"
                android:text="全部歌曲"/>
            <LinearLayout
                android:orientation="vertical"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <LinearLayout
                    android:orientation="horizontal"
                    android:id="@+id/layoutMusicPlazaLegacyHeader"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <TextView
                        android:id="@+id/btnMusicPlazaFilterAll"
                        android:layout_width="wrap_content"
                        android:layout_height="30dp"
                        android:text="全部歌曲"/>
                    <TextView
                        android:id="@+id/btnMusicPlazaFilterMine"
                        android:layout_width="wrap_content"
                        android:layout_height="30dp"
                        android:text="我的上传"/>
                    <TextView
                        android:id="@+id/btnMusicPlazaMineManage"
                        android:layout_width="wrap_content"
                        android:layout_height="30dp"
                        android:text="管理上传"/>
                </LinearLayout>
                <LinearLayout
                    android:orientation="horizontal"
                    android:id="@+id/layoutMusicPlazaHero"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <ImageView
                        android:id="@+id/ivMusicPlazaFeaturedCover"
                        android:layout_width="1dp"
                        android:layout_height="1dp"
                        android:src="@drawable/ic_avatar_placeholder"/>
                    <TextView
                        android:id="@+id/tvMusicPlazaFeaturedTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                    <TextView
                        android:id="@+id/tvMusicPlazaFeaturedSub"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                    <TextView
                        android:id="@+id/btnMusicPlazaFeaturedPlay"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="播放"/>
                </LinearLayout>
                <TextView
                    android:id="@+id/tvMusicPlazaPageInfo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
                <TextView
                    android:id="@+id/btnMusicPlazaPrev"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="上一页"/>
                <TextView
                    android:id="@+id/btnMusicPlazaNext"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="下一页"/>
                <ListView
                    android:id="@+id/lvMusicPlaza"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>
                <TextView
                    android:id="@+id/tvMusicPlazaEmpty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="暂无歌曲"/>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
