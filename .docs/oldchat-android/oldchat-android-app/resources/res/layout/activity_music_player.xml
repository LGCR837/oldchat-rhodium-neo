<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="@drawable/bg_music_player_page"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:background="@drawable/bg_music_player_topbar"
        android:paddingLeft="12dp"
        android:paddingRight="12dp"
        android:layout_width="match_parent"
        android:layout_height="58dp">
        <ImageView
            android:id="@+id/btnMusicPlayerBack"
            android:background="@drawable/bg_music_player_control_circle"
            android:padding="8dp"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:src="@drawable/ic_nav_back"
            android:contentDescription="返回"/>
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginLeft="12dp"
            android:layout_weight="1">
            <TextView
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/color_text_primary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="正在播放"/>
            <TextView
                android:textSize="11sp"
                android:textColor="@color/color_text_secondary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="支持后台播放与通知栏控制"/>
        </LinearLayout>
        <TextView
            android:textSize="11sp"
            android:textColor="@color/color_text_secondary"
            android:id="@+id/tvMusicPlayerHint"
            android:background="@drawable/bg_music_player_chip"
            android:paddingLeft="9dp"
            android:paddingTop="3dp"
            android:paddingRight="9dp"
            android:paddingBottom="3dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="后台"/>
        <TextView
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="@color/color_on_primary"
            android:gravity="center"
            android:id="@+id/btnMusicPlayerDownload"
            android:background="@drawable/bg_music_player_action_btn_primary"
            android:paddingLeft="12dp"
            android:paddingRight="12dp"
            android:layout_width="wrap_content"
            android:layout_height="34dp"
            android:layout_marginLeft="8dp"
            android:minWidth="60dp"
            android:text="下载"/>
    </LinearLayout>
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:layout_weight="1">
        <LinearLayout
            android:orientation="vertical"
            android:paddingLeft="12dp"
            android:paddingTop="12dp"
            android:paddingRight="12dp"
            android:paddingBottom="16dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <LinearLayout
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:background="@drawable/bg_music_player_card"
                android:padding="14dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <FrameLayout
                    android:background="@drawable/bg_music_player_cover_shell"
                    android:padding="7dp"
                    android:layout_width="248dp"
                    android:layout_height="248dp">
                    <ImageView
                        android:id="@+id/ivMusicPlayerCover"
                        android:background="@drawable/bg_music_player_cover_inner"
                        android:padding="4dp"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/ic_avatar_placeholder"
                        android:scaleType="centerCrop"
                        android:contentDescription="封面"/>
                </FrameLayout>
                <TextView
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="@color/color_text_primary"
                    android:ellipsize="end"
                    android:gravity="center"
                    android:id="@+id/tvMusicPlayerSongName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="歌曲名"
                    android:maxLines="2"/>
                <TextView
                    android:textSize="13sp"
                    android:textColor="@color/color_text_secondary"
                    android:ellipsize="end"
                    android:gravity="center"
                    android:id="@+id/tvMusicPlayerOwner"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="5dp"
                    android:text="上传者"
                    android:maxLines="1"/>
                <TextView
                    android:textSize="12sp"
                    android:textColor="@color/color_text_secondary"
                    android:id="@+id/tvMusicPlayerStatus"
                    android:background="@drawable/bg_music_player_chip"
                    android:paddingLeft="10dp"
                    android:paddingTop="4dp"
                    android:paddingRight="10dp"
                    android:paddingBottom="4dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="准备播放"/>
            </LinearLayout>
            <LinearLayout
                android:orientation="vertical"
                android:background="@drawable/bg_music_player_card"
                android:padding="12dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp">
                <TextView
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/color_text_primary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="播放进度"/>
                <SeekBar
                    android:id="@+id/sbMusicPlayerProgress"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:max="100"
                    android:progress="0"
                    android:progressDrawable="@drawable/bg_music_player_seekbar"
                    android:thumb="@drawable/bg_music_player_seekbar_thumb"
                    android:thumbOffset="0dp"/>
                <LinearLayout
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="5dp">
                    <TextView
                        android:textSize="12sp"
                        android:textColor="@color/color_text_secondary"
                        android:id="@+id/tvMusicPlayerCurrent"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="00:00"
                        android:layout_weight="1"/>
                    <TextView
                        android:textSize="12sp"
                        android:textColor="@color/color_text_secondary"
                        android:gravity="right"
                        android:id="@+id/tvMusicPlayerDuration"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="00:00"
                        android:layout_weight="1"/>
                </LinearLayout>
            </LinearLayout>
            <LinearLayout
                android:gravity="center"
                android:orientation="horizontal"
                android:background="@drawable/bg_music_player_card"
                android:paddingLeft="4dp"
                android:paddingTop="12dp"
                android:paddingRight="4dp"
                android:paddingBottom="10dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp">
                <LinearLayout
                    android:gravity="center"
                    android:orientation="vertical"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1">
                    <ImageView
                        android:id="@+id/btnMusicPlayerFastForward"
                        android:background="@drawable/bg_music_player_control_circle"
                        android:padding="12dp"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@android:drawable/ic_media_ff"
                        android:contentDescription="快进10秒"/>
                    <TextView
                        android:textSize="11sp"
                        android:textColor="@color/color_text_secondary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="快进"/>
                </LinearLayout>
                <LinearLayout
                    android:gravity="center"
                    android:orientation="vertical"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1">
                    <ImageView
                        android:id="@+id/btnMusicPlayerPlayPause"
                        android:background="@drawable/bg_music_player_control_circle_primary"
                        android:padding="16dp"
                        android:layout_width="62dp"
                        android:layout_height="62dp"
                        android:src="@android:drawable/ic_media_play"
                        android:contentDescription="播放或暂停"/>
                    <TextView
                        android:textSize="11sp"
                        android:textColor="@color/color_text_secondary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="播放/暂停"/>
                </LinearLayout>
                <LinearLayout
                    android:gravity="center"
                    android:orientation="vertical"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1">
                    <ImageView
                        android:id="@+id/btnMusicPlayerRepeatOne"
                        android:background="@drawable/bg_music_player_control_circle"
                        android:padding="12dp"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@android:drawable/ic_menu_rotate"
                        android:contentDescription="单曲循环"/>
                    <TextView
                        android:textSize="11sp"
                        android:textColor="@color/color_text_secondary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="循环"/>
                </LinearLayout>
                <LinearLayout
                    android:gravity="center"
                    android:orientation="vertical"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1">
                    <ImageView
                        android:id="@+id/btnMusicPlayerStop"
                        android:background="@drawable/bg_music_player_control_circle"
                        android:padding="12dp"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@android:drawable/ic_menu_close_clear_cancel"
                        android:contentDescription="停止"/>
                    <TextView
                        android:textSize="11sp"
                        android:textColor="@color/color_text_secondary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="停止"/>
                </LinearLayout>
            </LinearLayout>
            <LinearLayout
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:background="@drawable/bg_music_player_card"
                android:paddingLeft="10dp"
                android:paddingTop="10dp"
                android:paddingRight="10dp"
                android:paddingBottom="10dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp">
                <TextView
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/color_text_primary"
                    android:gravity="center"
                    android:id="@+id/btnMusicPlayerLike"
                    android:background="@drawable/bg_music_player_action_btn"
                    android:paddingLeft="12dp"
                    android:paddingRight="12dp"
                    android:layout_width="0dp"
                    android:layout_height="34dp"
                    android:layout_marginRight="6dp"
                    android:text="点赞 0"
                    android:layout_weight="1"/>
                <TextView
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/color_text_primary"
                    android:gravity="center"
                    android:id="@+id/btnMusicPlayerComments"
                    android:background="@drawable/bg_music_player_action_btn"
                    android:paddingLeft="12dp"
                    android:paddingRight="12dp"
                    android:layout_width="0dp"
                    android:layout_height="34dp"
                    android:layout_marginLeft="6dp"
                    android:text="评论 0"
                    android:layout_weight="1"/>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
