<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="@color/color_background"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <FrameLayout
        android:background="@drawable/bg_profile_item"
        android:layout_width="match_parent"
        android:layout_height="172dp"
        android:layout_marginLeft="2dp"
        android:layout_marginTop="2dp"
        android:layout_marginRight="2dp">
        <ImageView
            android:id="@+id/ivSpaceCover"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:contentDescription="@null"/>
        <View
            android:background="#22000000"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>
        <ImageView
            android:layout_gravity="top|left"
            android:id="@+id/btnSpaceBack"
            android:background="@drawable/bg_space_back_button"
            android:padding="8dp"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_margin="12dp"
            android:src="@drawable/ic_nav_back"
            android:tint="@color/color_on_primary"
            android:contentDescription="@null"/>
    </FrameLayout>
    <LinearLayout
        android:orientation="vertical"
        android:background="@drawable/bg_profile_item"
        android:padding="14dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="2dp"
        android:layout_marginTop="10dp"
        android:layout_marginRight="2dp">
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <com.im.oldchat.ui.widget.RoundedImageView
                android:id="@+id/ivSpaceAvatar"
                android:background="@drawable/bg_avatar_round"
                android:layout_width="68dp"
                android:layout_height="68dp"
                android:scaleType="centerCrop"
                android:contentDescription="@null"
                app:cornerRadius="0dp"
                app:srcCompat="@drawable/ic_avatar_placeholder"/>
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginLeft="12dp"
                android:layout_weight="1">
                <LinearLayout
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <TextView
                        android:textSize="19sp"
                        android:textStyle="bold"
                        android:textColor="@color/color_text_primary"
                        android:ellipsize="end"
                        android:id="@+id/tvSpaceName"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:maxLines="1"
                        android:layout_weight="1"/>
                    <TextView
                        android:textSize="10sp"
                        android:textColor="@color/color_on_primary"
                        android:ellipsize="end"
                        android:gravity="center"
                        android:id="@+id/tvSpaceTitleBadge"
                        android:background="@drawable/bg_badge_title"
                        android:paddingLeft="4dp"
                        android:paddingTop="1dp"
                        android:paddingRight="4dp"
                        android:paddingBottom="1dp"
                        android:visibility="gone"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="6dp"
                        android:maxWidth="92dp"
                        android:text="头衔"
                        android:maxLines="1"
                        android:singleLine="true"
                        android:includeFontPadding="false"/>
                </LinearLayout>
                <TextView
                    android:textSize="12sp"
                    android:textColor="@color/color_text_secondary"
                    android:id="@+id/tvSpaceUid"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"/>
                <TextView
                    android:textSize="14sp"
                    android:textColor="@color/color_text_primary"
                    android:ellipsize="end"
                    android:id="@+id/tvSpaceSignature"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:maxLines="2"/>
            </LinearLayout>
        </LinearLayout>
        <LinearLayout
            android:orientation="horizontal"
            android:id="@+id/space_button_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp">
            <TextView
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="?attr/colorPrimary"
                android:gravity="center"
                android:id="@+id/btnSpaceEdit"
                android:background="@drawable/button_outline_primary"
                android:layout_width="0dp"
                android:layout_height="42dp"
                android:text="编辑资料"
                android:layout_weight="1"/>
            <TextView
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/color_on_primary"
                android:gravity="center"
                android:id="@+id/btnSpacePost"
                android:background="@drawable/bg_primary_button"
                android:layout_width="0dp"
                android:layout_height="42dp"
                android:layout_marginLeft="10dp"
                android:text="发布动态"
                android:layout_weight="1"/>
        </LinearLayout>
        <LinearLayout
            android:orientation="horizontal"
            android:id="@+id/space_action_row"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp">
            <TextView
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/color_on_primary"
                android:gravity="center"
                android:id="@+id/btnSpacePrimary"
                android:background="@drawable/bg_primary_button"
                android:layout_width="0dp"
                android:layout_height="42dp"
                android:text="加好友"
                android:layout_weight="1"/>
            <TextView
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/colorDanger"
                android:gravity="center"
                android:id="@+id/btnSpaceReport"
                android:background="@drawable/button_outline_danger"
                android:layout_width="0dp"
                android:layout_height="42dp"
                android:layout_marginLeft="10dp"
                android:text="举报用户"
                android:layout_weight="1"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
