<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="@color/color_background"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:background="@color/color_surface"
        android:paddingLeft="12dp"
        android:paddingRight="12dp"
        android:layout_width="match_parent"
        android:layout_height="56dp">
        <android.support.v7.widget.AppCompatImageView
            android:id="@+id/btnRegisterBack"
            android:padding="6dp"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:tint="@color/color_text_primary"
            android:contentDescription="@null"
            app:srcCompat="@drawable/ic_nav_back"/>
        <TextView
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/color_text_primary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="8dp"
            android:text="@string/register_title"/>
    </LinearLayout>
    <View
        android:background="@color/color_divider"
        android:layout_width="match_parent"
        android:layout_height="1dp"/>
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">
        <LinearLayout
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingLeft="16dp"
            android:paddingTop="18dp"
            android:paddingRight="16dp"
            android:paddingBottom="18dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <LinearLayout
                android:orientation="vertical"
                android:background="@drawable/bg_login_card"
                android:paddingLeft="18dp"
                android:paddingTop="18dp"
                android:paddingRight="18dp"
                android:paddingBottom="18dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/color_text_primary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/register_title"/>
                <EditText
                    android:id="@+id/etUsername"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:hint="@string/username_hint"
                    android:inputType="text"/>
                <EditText
                    android:id="@+id/etEmail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:hint="@string/email_hint"
                    android:inputType="textEmailAddress"/>
                <LinearLayout
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp">
                    <EditText
                        android:id="@+id/etCaptcha"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:hint="@string/captcha_hint"
                        android:maxLength="5"
                        android:layout_weight="1"
                        android:inputType="number"/>
                    <ImageView
                        android:id="@+id/ivCaptcha"
                        android:background="@drawable/bg_search_field"
                        android:layout_width="120dp"
                        android:layout_height="48dp"
                        android:layout_marginLeft="10dp"
                        android:contentDescription="@null"/>
                </LinearLayout>
                <LinearLayout
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp">
                    <EditText
                        android:id="@+id/etEmailCode"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:hint="@string/email_code_hint"
                        android:maxLength="6"
                        android:layout_weight="1"
                        android:inputType="number"/>
                    <Button
                        android:id="@+id/btnSendEmailCode"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="10dp"
                        android:text="@string/send_email_code"
                        style="@style/FlatButtonOutline"/>
                </LinearLayout>
                <EditText
                    android:id="@+id/etPassword"
                    android:saveEnabled="false"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:hint="@string/password_hint"
                    android:freezesText="false"
                    android:inputType="textPassword"/>
                <LinearLayout
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp">
                    <CheckBox
                        android:id="@+id/cbPrivacyAgree"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                    <TextView
                        android:textSize="12sp"
                        android:textColor="@color/color_text_secondary"
                        android:id="@+id/tvPrivacyPolicy"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="6dp"
                        android:text="@string/privacy_policy_agree_text"
                        android:layout_weight="1"/>
                </LinearLayout>
                <Button
                    android:id="@+id/btnRegister"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:text="@string/register_button"
                    style="@style/FlatButtonPrimary"/>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
