<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="@color/color_background"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:orientation="vertical"
        android:background="@drawable/bg_search_header"
        android:paddingBottom="10dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="12dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <ImageView
                android:id="@+id/btnSearchBack"
                android:padding="6dp"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_nav_back"
                android:contentDescription="@null"/>
            <TextView
                android:textSize="19sp"
                android:textStyle="bold"
                android:textColor="@color/color_text_primary"
                android:id="@+id/tvSearchTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="8dp"
                android:text="查找聊天记录"/>
        </LinearLayout>
        <TextView
            android:textSize="13sp"
            android:textColor="@color/color_text_secondary"
            android:ellipsize="end"
            android:id="@+id/tvSearchContext"
            android:paddingLeft="14dp"
            android:paddingRight="14dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxLines="1"/>
    </LinearLayout>
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:background="@drawable/bg_list_item_surface"
        android:padding="8dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="12dp"
        android:layout_marginTop="10dp"
        android:layout_marginRight="12dp"
        android:layout_marginBottom="8dp">
        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginLeft="2dp"
            android:layout_marginRight="6dp"
            android:src="@android:drawable/ic_menu_search"
            android:tint="@color/color_text_secondary"
            android:contentDescription="@null"/>
        <EditText
            android:textColor="@color/color_text_primary"
            android:textColorHint="@color/color_text_secondary"
            android:id="@+id/etSearchKeyword"
            android:background="@drawable/bg_search_field"
            android:paddingLeft="10dp"
            android:paddingRight="10dp"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:hint="搜索关键词（支持文本/文件链接）"
            android:singleLine="true"
            android:layout_weight="1"
            android:imeOptions="actionSearch"/>
        <TextView
            android:textSize="13sp"
            android:textColor="@color/color_text_primary"
            android:gravity="center"
            android:id="@+id/btnSearchClear"
            android:background="@drawable/flat_button_bg"
            android:paddingLeft="10dp"
            android:paddingRight="10dp"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="34dp"
            android:layout_marginLeft="8dp"
            android:minWidth="50dp"
            android:text="清空"/>
        <TextView
            android:textSize="14sp"
            android:textColor="@color/color_on_primary"
            android:gravity="center"
            android:id="@+id/btnSearchAction"
            android:background="@drawable/bg_primary_button"
            android:paddingLeft="14dp"
            android:paddingRight="14dp"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:layout_marginLeft="8dp"
            android:minWidth="64dp"
            android:text="搜索"/>
    </LinearLayout>
    <HorizontalScrollView
        android:paddingLeft="12dp"
        android:paddingRight="12dp"
        android:scrollbars="none"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            <TextView
                android:textSize="13sp"
                android:textColor="@color/color_text_primary"
                android:gravity="center"
                android:id="@+id/btnFilterAll"
                android:background="@drawable/bg_search_filter_chip"
                android:paddingLeft="12dp"
                android:paddingRight="12dp"
                android:layout_width="wrap_content"
                android:layout_height="30dp"
                android:text="全部"/>
            <TextView
                android:textSize="13sp"
                android:textColor="@color/color_text_primary"
                android:gravity="center"
                android:id="@+id/btnFilterText"
                android:background="@drawable/bg_search_filter_chip"
                android:paddingLeft="12dp"
                android:paddingRight="12dp"
                android:layout_width="wrap_content"
                android:layout_height="30dp"
                android:layout_marginLeft="8dp"
                android:text="文字"/>
            <TextView
                android:textSize="13sp"
                android:textColor="@color/color_text_primary"
                android:gravity="center"
                android:id="@+id/btnFilterMedia"
                android:background="@drawable/bg_search_filter_chip"
                android:paddingLeft="12dp"
                android:paddingRight="12dp"
                android:layout_width="wrap_content"
                android:layout_height="30dp"
                android:layout_marginLeft="8dp"
                android:text="媒体"/>
        </LinearLayout>
    </HorizontalScrollView>
    <TextView
        android:textSize="12sp"
        android:textColor="@color/color_text_secondary"
        android:ellipsize="end"
        android:id="@+id/tvSearchSummary"
        android:paddingLeft="14dp"
        android:paddingTop="8dp"
        android:paddingRight="14dp"
        android:paddingBottom="6dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="请输入关键词开始搜索"
        android:singleLine="true"/>
    <FrameLayout
        android:background="@drawable/bg_list_item_surface"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginLeft="10dp"
        android:layout_marginRight="10dp"
        android:layout_marginBottom="8dp"
        android:layout_weight="1">
        <ListView
            android:id="@+id/lvSearchMessages"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:clipToPadding="false"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:listSelector="@android:color/transparent"
            android:divider="@android:color/transparent"
            android:dividerHeight="0dp"
            android:overScrollMode="ifContentScrolls"/>
        <TextView
            android:textSize="14sp"
            android:textColor="@color/color_text_secondary"
            android:gravity="center"
            android:layout_gravity="center"
            android:id="@+id/tvSearchEmpty"
            android:padding="24dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="暂无搜索结果"/>
    </FrameLayout>
    <TextView
        android:textSize="14sp"
        android:textColor="@color/color_text_secondary"
        android:gravity="center"
        android:id="@+id/btnSearchLoadMore"
        android:background="@drawable/flat_button_bg"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="42dp"
        android:layout_marginLeft="12dp"
        android:layout_marginRight="12dp"
        android:layout_marginBottom="8dp"
        android:text="加载更多"/>
</LinearLayout>
