<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/colorBubbleIn"/>
            <corners
                android:topLeftRadius="?attr/chatBubbleAvatarCornerRadius"
                android:topRightRadius="?attr/chatBubbleCornerRadius"
                android:bottomLeftRadius="?attr/chatBubbleCornerRadius"
                android:bottomRightRadius="?attr/chatBubbleCornerRadius"/>
            <stroke
                android:width="1dp"
                android:color="@color/color_divider"/>
        </shape>
    </item>
    <item
        android:left="1dp"
        android:top="1dp"
        android:right="1dp"
        android:bottom="1dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/color_row_pressed"/>
            <corners
                android:topLeftRadius="?attr/chatBubbleAvatarCornerRadius"
                android:topRightRadius="?attr/chatBubbleCornerRadius"
                android:bottomLeftRadius="?attr/chatBubbleCornerRadius"
                android:bottomRightRadius="?attr/chatBubbleCornerRadius"/>
        </shape>
    </item>
</layer-list>
