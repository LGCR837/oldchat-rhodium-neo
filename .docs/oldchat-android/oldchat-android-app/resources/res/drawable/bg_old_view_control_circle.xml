<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#dde8f1"/>
            <stroke
                android:width="1dp"
                android:color="#b8cbd9"/>
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#f7fbff"/>
            <stroke
                android:width="1dp"
                android:color="#c5d5e0"/>
        </shape>
    </item>
</selector>
