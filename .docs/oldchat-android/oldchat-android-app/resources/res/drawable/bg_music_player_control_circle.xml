<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#dce9f3"/>
            <stroke
                android:width="1dp"
                android:color="#b7cbda"/>
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#f7fbff"/>
            <stroke
                android:width="1dp"
                android:color="#c3d3df"/>
        </shape>
    </item>
</selector>
