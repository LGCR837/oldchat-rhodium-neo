<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#2b3948"/>
            <stroke
                android:width="1dp"
                android:color="#3f5265"/>
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#212c38"/>
            <stroke
                android:width="1dp"
                android:color="#344455"/>
        </shape>
    </item>
</selector>
