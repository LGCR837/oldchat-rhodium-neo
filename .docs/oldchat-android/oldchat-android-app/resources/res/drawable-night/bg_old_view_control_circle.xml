<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#2a3745"/>
            <stroke
                android:width="1dp"
                android:color="#435768"/>
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#1f2a35"/>
            <stroke
                android:width="1dp"
                android:color="#3a4c5b"/>
        </shape>
    </item>
</selector>
